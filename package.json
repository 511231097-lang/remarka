{
  "name": "remarka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:prod": "npm run web:build && npm run web:start",
    "worker:dev": "npm --prefix apps/worker run dev",
    "worker:reembed:contextual": "node --env-file-if-exists=apps/web/.env.local --env-file-if-exists=apps/worker/.env --env-file-if-exists=.env --env-file-if-exists=.env.eval --import tsx apps/worker/scripts/reembedContextual.ts",
    "worker:start": "npm --prefix apps/worker run start",
    "db:generate": "npm --prefix packages/db run prisma:generate",
    "db:migrate": "npm --prefix packages/db run prisma:migrate:dev",
    "db:migrate:deploy": "npm --prefix packages/db run prisma:migrate:deploy",
    "db:backfill:metrics": "node --import tsx packages/db/src/backfillMetrics.ts",
    "db:backfill:text-corpus": "node --import tsx packages/db/src/backfillBookTextCorpus.ts",
    "eval:chat-regression": "node --env-file-if-exists=apps/web/.env.local --env-file-if-exists=apps/worker/.env --env-file-if-exists=.env --env-file-if-exists=.env.eval --import tsx apps/web/scripts/chatRegressionEval.ts",
    "eval:retrieval": "node --env-file-if-exists=apps/web/.env.local --env-file-if-exists=apps/worker/.env --env-file-if-exists=.env --env-file-if-exists=.env.eval --import tsx apps/web/scripts/retrievalEval.ts",
    "test:unit": "npm --prefix apps/web run test:unit",
    "docker:up": "docker compose up --build -d",
    "docker:up:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -d",
    "docker:down": "docker compose down",
    "docker:down:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose logs -f --tail=200",
    "docker:logs:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f --tail=200"
  },
  "dependencies": {
    "openai": "6.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0"
  }
}
