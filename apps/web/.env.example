NEXT_PUBLIC_APP_NAME=Remarka
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remarka
IMPORT_BLOB_DIR=/tmp/remarka-imports
IMPORT_MAX_FILE_BYTES=26214400
IMPORT_MAX_ZIP_UNCOMPRESSED_BYTES=52428800
BOOKS_STORAGE_PROVIDER=local
BOOKS_LOCAL_DIR=/tmp/remarka-imports/books
BOOKS_S3_BUCKET=
BOOKS_S3_REGION=us-east-1
BOOKS_S3_ENDPOINT=
BOOKS_S3_KEY_PREFIX=remarka/books
BOOKS_S3_FORCE_PATH_STYLE=true
BOOKS_S3_ACCESS_KEY_ID=
BOOKS_S3_SECRET_ACCESS_KEY=
BOOKS_S3_SESSION_TOKEN=
VERTEX_API_KEY=
VERTEX_BASE_URL=https://aiplatform.googleapis.com
VERTEX_CHAT_MODEL=gemini-3.1-flash-lite-preview
BOOK_CHAT_MODEL_PRO=gemini-3.1-pro-preview
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_DIM=768
VERTEX_RANKING_ENABLED=false
VERTEX_RANKING_PROJECT_ID=
VERTEX_RANKING_LOCATION=global
VERTEX_RANKING_MODEL=semantic-ranker-default@latest
VERTEX_RANKING_BASE_URL=https://discoveryengine.googleapis.com
VERTEX_RANKING_ACCESS_TOKEN=
VERTEX_RANKING_CANDIDATE_FACTOR=5
VERTEX_RANKING_MAX_CANDIDATES=80
VERTEX_RANKING_CONTENT_MAX_CHARS=3200
BOOK_CHAT_TOP_K=12
BOOK_CHAT_EXPERIMENT_BOOK_IDS=
BOOK_CHAT_EXPERIMENT_STRATEGY=default
BOOK_CHAT_FULL_BOOK_CONTEXT_TTL_MS=300000
BOOK_CHAT_SCENE_TOOLS_ENABLED=true

AUTH_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_BOOKS_API_KEY=

# OAuth callback base URL (example for local run)
NEXTAUTH_URL=http://localhost:3000
