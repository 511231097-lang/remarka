# === Captcha for unauthenticated forms (copyright complaint, etc.) ===
# Без значений — captcha-проверка no-op (dev). На проде задать обязательно.
# Поддерживаются два провайдера:
#   - smartcaptcha — Yandex SmartCaptcha (RU-домашний, без trans-border).
#     Создать капчу: https://console.cloud.yandex.ru/folders/<folder>/smartcaptcha
#   - turnstile — Cloudflare Turnstile (US/global).
#     Получить ключи: https://dash.cloudflare.com/?to=/:account/turnstile
# CAPTCHA_PROVIDER должен быть одинаков на сервере и клиенте — есть два env'а
# по требованию Next.js (NEXT_PUBLIC_* доступен в браузере, обычные — только server).
CAPTCHA_PROVIDER=
NEXT_PUBLIC_CAPTCHA_PROVIDER=
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# === Storage для вложений к жалобам правообладателей ===
# По умолчанию переиспользуют BOOKS_S3_* настройки выше — отдельный bucket
# не обязателен. Если нужен изолированный bucket / prefix — указать здесь.
COPYRIGHT_COMPLAINTS_STORAGE_PROVIDER=
COPYRIGHT_COMPLAINTS_LOCAL_DIR=
COPYRIGHT_COMPLAINTS_S3_BUCKET=
COPYRIGHT_COMPLAINTS_S3_REGION=
COPYRIGHT_COMPLAINTS_S3_ENDPOINT=
COPYRIGHT_COMPLAINTS_S3_KEY_PREFIX=remarka/copyright-complaints
COPYRIGHT_COMPLAINTS_S3_FORCE_PATH_STYLE=
COPYRIGHT_COMPLAINTS_S3_ACCESS_KEY_ID=
COPYRIGHT_COMPLAINTS_S3_SECRET_ACCESS_KEY=
COPYRIGHT_COMPLAINTS_S3_SESSION_TOKEN=
