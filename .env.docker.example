NEXT_PUBLIC_APP_NAME=Remarka
EXTRACT_LLM_PROVIDER=timeweb

TIMEWEB_API_TOKEN=
TIMEWEB_BASE_HOST=https://agent.timeweb.cloud
TIMEWEB_EXTRACT_PROFILE=qwen
TIMEWEB_EXTRACT_ACCESS_ID=
TIMEWEB_EXTRACT_MODEL=
TIMEWEB_TIMEOUT_MS=120000
TIMEWEB_MAX_RETRIES=2

KIA_API_KEY=
KIA_CHAT_BASE_URL=https://api.kie.ai/gemini-3-flash/v1
KIA_GEMINI_MODEL=gemini-3-flash-openai
KIA_TIMEOUT_MS=120000
KIA_MAX_RETRIES=2

PREPROCESSOR_URL=http://preprocessor:8010
PREPROCESSOR_TIMEOUT_MS=20000
PREPROCESSOR_RETRIES=3

OUTBOX_POLL_INTERVAL_MS=1200
OUTBOX_BATCH_SIZE=16
OUTBOX_MAX_ATTEMPTS=8

IMPORT_BLOB_DIR=/var/remarka/imports
IMPORT_MAX_FILE_BYTES=26214400
IMPORT_MAX_ZIP_UNCOMPRESSED_BYTES=52428800

PATCH_WINDOWS_CAP=32
PATCH_WINDOW_SIZE=12
ENABLE_EVENT_EXTRACTION=false
ANALYSIS_AUTO_RERUN_ENABLED=true
ANALYSIS_AUTO_RERUN_MAX_ATTEMPTS=1
ANALYSIS_AUTO_RERUN_EMPTY_MIN_CANDIDATES=120
ANALYSIS_AUTO_RERUN_EMPTY_MIN_CONTENT_CHARS=2500
ENTITY_PASS_BATCH_CANDIDATES=1200
ENTITY_PASS_BATCH_SNIPPETS_CAP=192
ENTITY_PASS_BATCH_SNIPPET_MAX_CHARS=1200
ENTITY_PASS_BATCH_CANDIDATE_TEXT_MAX_CHARS=160
ENTITY_PASS_KNOWN_ENTITIES_CAP=400
ENTITY_PASS_KNOWN_ALIASES_PER_ENTITY=8
ENTITY_PASS_SKIP_WHEN_NO_CANDIDATES=true
