NEXT_PUBLIC_APP_NAME=Remarka
AUTH_SECRET=change-me
# Google OAuth удалён в legal-edition v1.2 — оставлены пустые переменные
# для обратной совместимости deploy-скриптов, но провайдер не подключается.
# Если когда-нибудь решите вернуть Google — нужны и code-change в auth.ts,
# и эти ключи.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Yandex ID OAuth — единственный провайдер авторизации. Получить ключи:
# https://oauth.yandex.ru/client/new — указать redirect URI <NEXTAUTH_URL>/api/auth/callback/yandex
