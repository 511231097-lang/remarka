# Template for /srv/remarka/shared/env/worker.env on the production VPS.
#
# Same source-of-truth pattern as web.env.template — see that file's
# header for how envsubst + GitHub secrets/vars feed into this file at
# every `deploy-worker` pipeline run.

###############################################################################
# Runtime mode
###############################################################################
NODE_ENV=production

###############################################################################
# Database (SECRET — same DATABASE_URL as web)
###############################################################################
DATABASE_URL=${DATABASE_URL}

###############################################################################
# Vertex AI — same Gemini access as web (worker also calls LLM during analysis)
###############################################################################
VERTEX_API_KEY=${VERTEX_API_KEY}
VERTEX_BASE_URL=${VERTEX_BASE_URL}
BOOK_CHAT_MODEL_PRO=${BOOK_CHAT_MODEL_PRO}
BOOK_CHAT_MODEL_LITE=${BOOK_CHAT_MODEL_LITE}
VERTEX_MODEL_LITE=${VERTEX_MODEL_LITE}
VERTEX_EMBEDDING_MODEL=${VERTEX_EMBEDDING_MODEL}
VERTEX_EMBEDDING_DIM=${VERTEX_EMBEDDING_DIM}

# Vertex semantic ranker — worker doesn't call ranking directly, but the
# config travels alongside Vertex creds for symmetry.
VERTEX_RANKING_ENABLED=${VERTEX_RANKING_ENABLED}
VERTEX_RANKING_PROJECT_ID=${VERTEX_RANKING_PROJECT_ID}
VERTEX_RANKING_LOCATION=${VERTEX_RANKING_LOCATION}
GOOGLE_APPLICATION_CREDENTIALS=${GOOGLE_APPLICATION_CREDENTIALS}

###############################################################################
# Object storage (Timeweb S3) — books + analysis artifacts
###############################################################################
BOOKS_STORAGE_PROVIDER=${BOOKS_STORAGE_PROVIDER}
BOOKS_S3_ENDPOINT=${BOOKS_S3_ENDPOINT}
BOOKS_S3_BUCKET=${BOOKS_S3_BUCKET}
BOOKS_S3_REGION=${BOOKS_S3_REGION}
BOOKS_S3_FORCE_PATH_STYLE=${BOOKS_S3_FORCE_PATH_STYLE}
BOOKS_S3_KEY_PREFIX=${BOOKS_S3_KEY_PREFIX}
BOOKS_S3_ACCESS_KEY_ID=${BOOKS_S3_ACCESS_KEY_ID}
BOOKS_S3_SECRET_ACCESS_KEY=${BOOKS_S3_SECRET_ACCESS_KEY}

ANALYSIS_ARTIFACTS_ENABLED=${ANALYSIS_ARTIFACTS_ENABLED}
ARTIFACTS_STORAGE_PROVIDER=${ARTIFACTS_STORAGE_PROVIDER}
ARTIFACTS_S3_ENDPOINT=${ARTIFACTS_S3_ENDPOINT}
ARTIFACTS_S3_BUCKET=${ARTIFACTS_S3_BUCKET}
ARTIFACTS_S3_REGION=${ARTIFACTS_S3_REGION}
ARTIFACTS_S3_FORCE_PATH_STYLE=${ARTIFACTS_S3_FORCE_PATH_STYLE}
ARTIFACTS_S3_KEY_PREFIX=${ARTIFACTS_S3_KEY_PREFIX}
ARTIFACTS_S3_ACCESS_KEY_ID=${ARTIFACTS_S3_ACCESS_KEY_ID}
ARTIFACTS_S3_SECRET_ACCESS_KEY=${ARTIFACTS_S3_SECRET_ACCESS_KEY}

###############################################################################
# Internal web ↔ worker handshake (SECRET — must match web's value)
###############################################################################
INTERNAL_WORKER_TOKEN=${INTERNAL_WORKER_TOKEN}

###############################################################################
# pg-boss queue + analysis dispatcher
###############################################################################
ANALYSIS_QUEUE_MODE=${ANALYSIS_QUEUE_MODE}
ANALYSIS_DISPATCHER_ENABLED=${ANALYSIS_DISPATCHER_ENABLED}
ANALYSIS_EXECUTOR_CONCURRENCY=${ANALYSIS_EXECUTOR_CONCURRENCY}
ANALYSIS_JOB_RETRY_LIMIT=${ANALYSIS_JOB_RETRY_LIMIT}
ANALYSIS_JOB_RETRY_BASE_MS=${ANALYSIS_JOB_RETRY_BASE_MS}
ANALYSIS_WATCHDOG_INTERVAL_MS=${ANALYSIS_WATCHDOG_INTERVAL_MS}
ANALYSIS_RUNNING_STALE_TTL_MS=${ANALYSIS_RUNNING_STALE_TTL_MS}
ANALYSIS_QUEUED_STALE_TTL_MS=${ANALYSIS_QUEUED_STALE_TTL_MS}

###############################################################################
# Outbox poller (web writes events, worker drains)
###############################################################################
OUTBOX_POLL_INTERVAL_MS=${OUTBOX_POLL_INTERVAL_MS}
OUTBOX_BATCH_SIZE=${OUTBOX_BATCH_SIZE}
OUTBOX_MAX_ATTEMPTS=${OUTBOX_MAX_ATTEMPTS}

###############################################################################
# Scene segmentation (chapter-aware, with safe-mode cap on input tokens)
###############################################################################
ANALYSIS_SCENES_ENABLED=${ANALYSIS_SCENES_ENABLED}
SCENE_SEGMENTATION_STRATEGY=${SCENE_SEGMENTATION_STRATEGY}
SCENE_SEGMENTATION_MAX_INPUT_TOKENS=${SCENE_SEGMENTATION_MAX_INPUT_TOKENS}
ANALYSIS_SAFE_SCENE_SEGMENTS_ENABLED=${ANALYSIS_SAFE_SCENE_SEGMENTS_ENABLED}
ANALYSIS_SAFE_SCENE_SEGMENTS_MAX_INPUT_TOKENS=${ANALYSIS_SAFE_SCENE_SEGMENTS_MAX_INPUT_TOKENS}
ANALYSIS_PARAGRAPH_SCENE_PARALLEL_ENABLED=${ANALYSIS_PARAGRAPH_SCENE_PARALLEL_ENABLED}

###############################################################################
# Embedding throughput (book ingest)
###############################################################################
BOOK_EMBEDDING_CONCURRENCY=${BOOK_EMBEDDING_CONCURRENCY}

###############################################################################
# Vertex token budgets (worker uses both lite + pro)
###############################################################################
VERTEX_MAX_OUTPUT_TOKENS=${VERTEX_MAX_OUTPUT_TOKENS}
VERTEX_LITERARY_MAX_TOKENS=${VERTEX_LITERARY_MAX_TOKENS}
VERTEX_THINKING_BUDGET=${VERTEX_THINKING_BUDGET}
VERTEX_TIMEOUT_MS=${VERTEX_TIMEOUT_MS}
VERTEX_MAX_RETRIES=${VERTEX_MAX_RETRIES}

###############################################################################
# Scene-edge classifier batch sizing
###############################################################################
BOOK_SCENE_EDGE_BATCH_SIZE=${BOOK_SCENE_EDGE_BATCH_SIZE}
BOOK_SCENE_EDGE_BATCH_CONCURRENCY=${BOOK_SCENE_EDGE_BATCH_CONCURRENCY}
BOOK_SCENE_EDGE_CHAR_LIMIT=${BOOK_SCENE_EDGE_CHAR_LIMIT}
BOOK_SCENE_EDGE_MAX_TOKENS=${BOOK_SCENE_EDGE_MAX_TOKENS}
BOOK_SCENE_EDGE_MAX_ATTEMPTS=${BOOK_SCENE_EDGE_MAX_ATTEMPTS}

###############################################################################
# Local import staging — kept on worker host. Bucketed S3 takes the final copy.
###############################################################################
IMPORT_BLOB_DIR=${IMPORT_BLOB_DIR}
IMPORT_MAX_FILE_BYTES=${IMPORT_MAX_FILE_BYTES}
IMPORT_MAX_ZIP_UNCOMPRESSED_BYTES=${IMPORT_MAX_ZIP_UNCOMPRESSED_BYTES}

###############################################################################
# Showcase / public catalog rebuild — talks back to web's internal API
###############################################################################
SHOWCASE_BUILD_ENABLED=${SHOWCASE_BUILD_ENABLED}
SHOWCASE_INTERNAL_API_BASE_URL=${SHOWCASE_INTERNAL_API_BASE_URL}
SHOWCASE_INTERNAL_API_TIMEOUT_MS=${SHOWCASE_INTERNAL_API_TIMEOUT_MS}
SHOWCASE_INTERNAL_API_MAX_RETRIES=${SHOWCASE_INTERNAL_API_MAX_RETRIES}
