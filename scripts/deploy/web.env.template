# Template for /srv/remarka/shared/env/web.env on the production VPS.
#
# THIS FILE IS THE SOURCE OF TRUTH for which env vars web.service expects.
# Names that appear here as ${NAME} get substituted with values pulled from
# GitHub on every `deploy-web` pipeline run (envsubst).
#
# Where each value comes from:
#   - GitHub Repository → Settings → Secrets    → for sensitive values
#   - GitHub Repository → Settings → Variables  → for non-sensitive config
#
# The matching list of names lives in `.github/workflows/pipeline.yml`
# under the `Render web.env from GitHub` step. Adding a new variable
# requires:
#   1. Add it here (with ${NAME} placeholder).
#   2. Add it to the env block of the render step in pipeline.yml.
#   3. Set the value in GitHub UI (or via `gh secret set` / `gh variable set`).
#
# To rotate any value: change it in GitHub → re-run the deploy.

###############################################################################
# Runtime mode (variable — same across all production deploys)
###############################################################################
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=${NEXT_PUBLIC_APP_NAME}

###############################################################################
# Database — managed Timeweb DBaaS (DATABASE_URL is a SECRET — embeds password)
###############################################################################
DATABASE_URL=${DATABASE_URL}

###############################################################################
# Vertex AI — Gemini chat / embeddings / ranking
###############################################################################
# SECRET: API key
VERTEX_API_KEY=${VERTEX_API_KEY}
# Variables: model identifiers and limits
VERTEX_BASE_URL=${VERTEX_BASE_URL}
BOOK_CHAT_MODEL_PRO=${BOOK_CHAT_MODEL_PRO}
BOOK_CHAT_MODEL_LITE=${BOOK_CHAT_MODEL_LITE}
VERTEX_MODEL_LITE=${VERTEX_MODEL_LITE}
VERTEX_EMBEDDING_MODEL=${VERTEX_EMBEDDING_MODEL}
VERTEX_EMBEDDING_DIM=${VERTEX_EMBEDDING_DIM}

# Vertex semantic ranker (variables — flag + project pointers)
VERTEX_RANKING_ENABLED=${VERTEX_RANKING_ENABLED}
VERTEX_RANKING_PROJECT_ID=${VERTEX_RANKING_PROJECT_ID}
VERTEX_RANKING_LOCATION=${VERTEX_RANKING_LOCATION}
# Path on the VPS — the JSON keyfile itself is shipped via the
# `Render Vertex ranking keyfile` step from the VERTEX_RANKING_KEYFILE_JSON
# secret. The path stays a static config value.
GOOGLE_APPLICATION_CREDENTIALS=${GOOGLE_APPLICATION_CREDENTIALS}

###############################################################################
# Object storage (Timeweb S3) — books bucket
###############################################################################
BOOKS_STORAGE_PROVIDER=${BOOKS_STORAGE_PROVIDER}
BOOKS_S3_ENDPOINT=${BOOKS_S3_ENDPOINT}
BOOKS_S3_BUCKET=${BOOKS_S3_BUCKET}
BOOKS_S3_REGION=${BOOKS_S3_REGION}
BOOKS_S3_FORCE_PATH_STYLE=${BOOKS_S3_FORCE_PATH_STYLE}
BOOKS_S3_KEY_PREFIX=${BOOKS_S3_KEY_PREFIX}
# SECRETS: bucket-scoped access keys
BOOKS_S3_ACCESS_KEY_ID=${BOOKS_S3_ACCESS_KEY_ID}
BOOKS_S3_SECRET_ACCESS_KEY=${BOOKS_S3_SECRET_ACCESS_KEY}

###############################################################################
# Object storage — analysis artifacts
###############################################################################
ANALYSIS_ARTIFACTS_ENABLED=${ANALYSIS_ARTIFACTS_ENABLED}
ARTIFACTS_STORAGE_PROVIDER=${ARTIFACTS_STORAGE_PROVIDER}
ARTIFACTS_S3_ENDPOINT=${ARTIFACTS_S3_ENDPOINT}
ARTIFACTS_S3_BUCKET=${ARTIFACTS_S3_BUCKET}
ARTIFACTS_S3_REGION=${ARTIFACTS_S3_REGION}
ARTIFACTS_S3_FORCE_PATH_STYLE=${ARTIFACTS_S3_FORCE_PATH_STYLE}
ARTIFACTS_S3_KEY_PREFIX=${ARTIFACTS_S3_KEY_PREFIX}
ARTIFACTS_S3_ACCESS_KEY_ID=${ARTIFACTS_S3_ACCESS_KEY_ID}
ARTIFACTS_S3_SECRET_ACCESS_KEY=${ARTIFACTS_S3_SECRET_ACCESS_KEY}

###############################################################################
# Internal web ↔ worker handshake (legacy — unused while SHOWCASE_BUILD_ENABLED=false)
#
# The showcase-builder feature is currently disabled (placeholders in the UI).
# When it gets revived, set INTERNAL_WORKER_TOKEN as a GitHub secret AND add
# the matching `INTERNAL_WORKER_TOKEN: ${{ secrets.INTERNAL_WORKER_TOKEN }}`
# line to the render-step in .github/workflows/pipeline.yml — both web and
# worker will pick it up on the next deploy. Until then the showcase
# internal API simply 403's any request (correct closed-by-default state).
###############################################################################
# INTERNAL_WORKER_TOKEN= (intentionally absent — see header above)

###############################################################################
# NextAuth + Yandex ID OAuth
###############################################################################
NEXTAUTH_URL=${NEXTAUTH_URL}
# SECRET: JWT signing key. Rotation logs everyone out — coordinate.
AUTH_SECRET=${AUTH_SECRET}
# Yandex OAuth client. CLIENT_ID is sometimes considered semi-public (lives
# in OAuth redirect URLs), CLIENT_SECRET is strictly secret.
YANDEX_CLIENT_ID=${YANDEX_CLIENT_ID}
YANDEX_CLIENT_SECRET=${YANDEX_CLIENT_SECRET}

###############################################################################
# Captcha (Yandex SmartCaptcha or Cloudflare Turnstile)
###############################################################################
CAPTCHA_PROVIDER=${CAPTCHA_PROVIDER}
NEXT_PUBLIC_CAPTCHA_PROVIDER=${NEXT_PUBLIC_CAPTCHA_PROVIDER}
NEXT_PUBLIC_CAPTCHA_SITE_KEY=${NEXT_PUBLIC_CAPTCHA_SITE_KEY}
# SECRET: backend verification key
CAPTCHA_SECRET_KEY=${CAPTCHA_SECRET_KEY}

###############################################################################
# Chat behaviour (variables — runtime tuning, no secrets)
###############################################################################
BOOK_CHAT_SCENE_TOOLS_ENABLED=${BOOK_CHAT_SCENE_TOOLS_ENABLED}
BOOK_CHAT_SYSTEM_PROMPT_VERSION=${BOOK_CHAT_SYSTEM_PROMPT_VERSION}
BOOK_CHAT_HISTORY_COMPACTION_ENABLED=${BOOK_CHAT_HISTORY_COMPACTION_ENABLED}
BOOK_CHAT_HISTORY_KEEP_INLINE_PAIRS=${BOOK_CHAT_HISTORY_KEEP_INLINE_PAIRS}
BOOK_CHAT_HISTORY_COMPACT_AFTER_PAIRS=${BOOK_CHAT_HISTORY_COMPACT_AFTER_PAIRS}
BOOK_CHAT_HISTORY_SUMMARY_MAX_CHARS=${BOOK_CHAT_HISTORY_SUMMARY_MAX_CHARS}
BOOK_CHAT_LLM_STEP_METRICS_ENABLED=${BOOK_CHAT_LLM_STEP_METRICS_ENABLED}
BOOK_CHAT_TOP_K=${BOOK_CHAT_TOP_K}
