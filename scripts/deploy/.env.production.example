# Remarka — production env template.
#
# Copy the relevant section to the VPS, then chmod 600. Real values:
#   /srv/remarka/shared/env/web.env
#   /srv/remarka/shared/env/worker.env
#
# NEVER commit a filled-in copy of this file. Placeholders use <ANGLE_BRACKETS>.

###############################################################################
# SECTION A — shared by web and worker
###############################################################################

# Postgres (managed Timeweb DBaaS).
# `pgbouncer` style port 6432 is the typical poolers; raw 5432 also works.
# `connection_limit=20` keeps each instance well under the cluster max conns.
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:6432/<DBNAME>?sslmode=require&connection_limit=20

# Vertex AI (Gemini).
VERTEX_API_KEY=<VERTEX_API_KEY>
VERTEX_BASE_URL=https://aiplatform.googleapis.com
BOOK_CHAT_MODEL_PRO=gemini-3.1-pro-preview
BOOK_CHAT_MODEL_LITE=gemini-3.1-flash-lite-preview
VERTEX_MODEL_LITE=gemini-3.1-flash-lite-preview
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_DIM=768

# Vertex semantic ranker (used by the chat retriever rerank step).
VERTEX_RANKING_ENABLED=true
VERTEX_RANKING_PROJECT_ID=<GCP_PROJECT_ID>
VERTEX_RANKING_LOCATION=global
# A service account JSON keyfile is required for Vertex Ranking API
# (the API key alone does not authorize the discoveryengine endpoint).
GOOGLE_APPLICATION_CREDENTIALS=/srv/remarka/shared/secrets/vertex-ranking.json

# S3-compatible object storage (Timeweb S3).
# One bucket holds both prefixes; access keys are bucket-scoped.
BOOKS_STORAGE_PROVIDER=s3
BOOKS_S3_ENDPOINT=https://s3.twcstorage.ru
BOOKS_S3_BUCKET=<S3_BUCKET>
BOOKS_S3_REGION=ru-1
BOOKS_S3_FORCE_PATH_STYLE=true
BOOKS_S3_KEY_PREFIX=remarka/books
BOOKS_S3_ACCESS_KEY_ID=<S3_ACCESS_KEY>
BOOKS_S3_SECRET_ACCESS_KEY=<S3_SECRET>

ANALYSIS_ARTIFACTS_ENABLED=true
ARTIFACTS_STORAGE_PROVIDER=s3
ARTIFACTS_S3_ENDPOINT=https://s3.twcstorage.ru
ARTIFACTS_S3_BUCKET=<S3_BUCKET>
ARTIFACTS_S3_REGION=ru-1
ARTIFACTS_S3_FORCE_PATH_STYLE=true
ARTIFACTS_S3_KEY_PREFIX=remarka/analysis-artifacts
ARTIFACTS_S3_ACCESS_KEY_ID=<S3_ACCESS_KEY>
ARTIFACTS_S3_SECRET_ACCESS_KEY=<S3_SECRET>

# Internal token used for web<->worker handshakes during showcase rebuilds.
INTERNAL_WORKER_TOKEN=<RANDOM_32_BYTES_BASE64>

###############################################################################
# SECTION B — web only (apps/web)
###############################################################################

NODE_ENV=production
NEXT_PUBLIC_APP_NAME=Remarka

# NextAuth — must match the public domain. Generate AUTH_SECRET with:
#   openssl rand -base64 32
NEXTAUTH_URL=https://<DOMAIN>
AUTH_SECRET=<NEXTAUTH_SECRET>

# Google OAuth (Cloud Console -> Credentials -> OAuth 2.0 Client).
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
GOOGLE_BOOKS_API_KEY=<GOOGLE_BOOKS_API_KEY>

# Yandex ID OAuth.
# https://oauth.yandex.ru/client/new — redirect URI:
#   <NEXTAUTH_URL>/api/auth/callback/yandex
YANDEX_CLIENT_ID=<YANDEX_CLIENT_ID>
YANDEX_CLIENT_SECRET=<YANDEX_CLIENT_SECRET>

# Bot protection for legal/copyright complaint form.
# Keep CAPTCHA_PROVIDER and NEXT_PUBLIC_CAPTCHA_PROVIDER identical.
# Supported values:
#   smartcaptcha — Yandex SmartCaptcha
#   turnstile    — Cloudflare Turnstile
CAPTCHA_PROVIDER=smartcaptcha
NEXT_PUBLIC_CAPTCHA_PROVIDER=smartcaptcha
NEXT_PUBLIC_CAPTCHA_SITE_KEY=<CAPTCHA_SITE_KEY>
CAPTCHA_SECRET_KEY=<CAPTCHA_SECRET_KEY>

# Chat behaviour.
BOOK_CHAT_SCENE_TOOLS_ENABLED=true
BOOK_CHAT_SYSTEM_PROMPT_VERSION=tool-aware-v3
BOOK_CHAT_HISTORY_COMPACTION_ENABLED=true
BOOK_CHAT_HISTORY_KEEP_INLINE_PAIRS=2
BOOK_CHAT_HISTORY_COMPACT_AFTER_PAIRS=3
BOOK_CHAT_HISTORY_SUMMARY_MAX_CHARS=500
BOOK_CHAT_LLM_STEP_METRICS_ENABLED=true
BOOK_CHAT_TOP_K=12

# Web doesn't need the worker-only analysis flags below, but if you ever
# trigger a sync analysis from the web (admin dashboard), they apply.

###############################################################################
# SECTION C — worker only (apps/worker)
###############################################################################

NODE_ENV=production

# pg-boss queue + analysis dispatcher.
ANALYSIS_QUEUE_MODE=pgboss-hybrid
ANALYSIS_DISPATCHER_ENABLED=true
ANALYSIS_EXECUTOR_CONCURRENCY=2
ANALYSIS_JOB_RETRY_LIMIT=5
ANALYSIS_JOB_RETRY_BASE_MS=5000
ANALYSIS_WATCHDOG_INTERVAL_MS=60000
ANALYSIS_RUNNING_STALE_TTL_MS=2700000
ANALYSIS_QUEUED_STALE_TTL_MS=600000

# Outbox poller (web writes events, worker drains).
OUTBOX_POLL_INTERVAL_MS=1200
OUTBOX_BATCH_SIZE=16
OUTBOX_MAX_ATTEMPTS=8

# Scene segmentation (chapter-aware, with a safe-mode cap on input tokens).
ANALYSIS_SCENES_ENABLED=true
SCENE_SEGMENTATION_STRATEGY=chapter_first
SCENE_SEGMENTATION_MAX_INPUT_TOKENS=60000
ANALYSIS_SAFE_SCENE_SEGMENTS_ENABLED=true
ANALYSIS_SAFE_SCENE_SEGMENTS_MAX_INPUT_TOKENS=40000
ANALYSIS_PARAGRAPH_SCENE_PARALLEL_ENABLED=true

# Embedding throughput (book ingest).
BOOK_EMBEDDING_CONCURRENCY=8

# Vertex token budgets (worker uses both lite + pro).
VERTEX_MAX_OUTPUT_TOKENS=8192
VERTEX_LITERARY_MAX_TOKENS=4096
VERTEX_THINKING_BUDGET=0
VERTEX_TIMEOUT_MS=120000
VERTEX_MAX_RETRIES=2

# Scene-edge classifier batch sizing.
BOOK_SCENE_EDGE_BATCH_SIZE=6
BOOK_SCENE_EDGE_BATCH_CONCURRENCY=8
BOOK_SCENE_EDGE_CHAR_LIMIT=140
BOOK_SCENE_EDGE_MAX_TOKENS=2048
BOOK_SCENE_EDGE_MAX_ATTEMPTS=1

# Local import staging — kept on the worker host. Bucketed S3 takes the final copy.
IMPORT_BLOB_DIR=/srv/remarka/shared/imports
IMPORT_MAX_FILE_BYTES=26214400
IMPORT_MAX_ZIP_UNCOMPRESSED_BYTES=52428800

# Showcase / public catalog rebuild — talks back to web's internal API.
SHOWCASE_BUILD_ENABLED=false
SHOWCASE_INTERNAL_API_BASE_URL=https://<DOMAIN>
SHOWCASE_INTERNAL_API_TIMEOUT_MS=45000
SHOWCASE_INTERNAL_API_MAX_RETRIES=2
