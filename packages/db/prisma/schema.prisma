model BookSearchDocument {
  id               String   @id @default(cuid())
  bookId           String
  contentVersionId String
  documentType     String
  documentId       String
  title            String?
  bodyText         String   @db.Text
  metadataJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([contentVersionId, documentType, documentId])
  @@index([bookId, contentVersionId, documentType])
}

model BookEvidenceHit {
  id               String   @id @default(cuid())
  bookId           String
  contentVersionId String
  subjectType      String
  subjectId        String
  linkedObjectIds  String[] @default([])
  spanRefJson      Json
  whyMatched       String
  snippet          String   @db.Text
  createdAt        DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, contentVersionId, subjectType, subjectId])
}

model BookPresenceMap {
  id                 String   @id @default(cuid())
  bookId             String
  contentVersionId   String
  entityId           String
  sceneId            String
  chapterOrderIndex  Int
  paragraphStart     Int
  paragraphEnd       Int
  mentionCount       Int      @default(0)
  copresentEntityIds String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([contentVersionId, entityId, sceneId])
  @@index([bookId, contentVersionId, sceneId])
}

model BookProcessingReport {
  id               String             @id @default(cuid())
  bookId           String
  contentVersionId String
  runId            String
  coverage         BookCoverageStatus @default(partial)
  reportJson       Json
  countsJson       Json
  unresolvedJson   Json
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, coverage])
  @@index([bookId, contentVersionId, createdAt])
  @@index([runId])
}

model BookChatTurnMetric {
  id                  String   @id @default(cuid())
  bookId              String
  threadId            String
  messageId           String   @unique
  chatModel           String
  embeddingModel      String
  selectedToolsJson   Json     @default("[]")
  toolConfigKey       String
  promptVariant       String
  systemPromptVersion String
  pricingVersion      String
  modelInputTokens    Int      @default(0)
  modelOutputTokens   Int      @default(0)
  modelTotalTokens    Int      @default(0)
  // Subset of modelInputTokens that hit Vertex implicit/explicit cache. Cached
  // tokens are billed at ~10% of normal input price (90% off). When >0 means
  // implicit cache fired on this turn.
  modelCachedInputTokens Int   @default(0)
  // "Thinking" tokens for Gemini 3.x and 2.5 thinking models. Billed as output
  // tokens but invisible in the final answer text. Tracking these separately
  // lets us measure how much "internal reasoning" each turn consumed.
  modelThoughtsTokens Int      @default(0)
  embeddingInputTokens Int     @default(0)
  chatCostUsd         Float    @default(0)
  embeddingCostUsd    Float    @default(0)
  totalCostUsd        Float    @default(0)
  totalLatencyMs      Int      @default(0)
  answerLengthChars   Int      @default(0)
  citationCount       Int      @default(0)
  fallbackUsed        Boolean  @default(false)
  fallbackKind        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  book    Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  thread  BookChatThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message BookChatThreadMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolRuns BookChatToolRun[]

  @@index([bookId, createdAt])
  @@index([threadId, createdAt])
}

model BookChatToolRun {
  id                 String   @id @default(cuid())
  turnMetricId       String
  toolName           String
  orderIndex         Int
  latencyMs          Int      @default(0)
  argsSummaryJson    Json     @default("{}")
  resultSummaryJson  Json     @default("{}")
  errorCode          String?
  errorMessage       String?
  storageProvider    String?
  payloadKey         String?
  payloadSizeBytes   Int      @default(0)
  payloadSha256      String?
  compression        String?
  createdAt          DateTime @default(now())

  turnMetric BookChatTurnMetric @relation(fields: [turnMetricId], references: [id], onDelete: Cascade)

  @@unique([turnMetricId, orderIndex])
  @@index([toolName, createdAt])
  @@index([turnMetricId, createdAt])
}

model Outbox {
  id            String    @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payloadJson   Json
  availableAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  error         String?
  attemptCount  Int       @default(0)

  @@index([processedAt, createdAt])
  @@index([processedAt, availableAt, createdAt], map: "Outbox_processedAt_availableAt_createdAt_idx")
  @@index([aggregateType, aggregateId])
}

model User {
  id                          String            @id @default(cuid())
  name                        String?
  email                       String?           @unique
  emailVerified               DateTime?
  image                       String?
  role                        UserRole          @default(user)
  accounts                    Account[]
  sessions                    Session[]
  books                       Book[]
  bookLikes                   BookLike[]
  bookChatSessions            BookChatSession[]
  chatThreads                 BookChatThread[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
