generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  character
  location
  event
}

enum AnalysisRunState {
  queued
  running
  completed
  failed
  superseded
}

enum AnalysisRunPhase {
  queued
  prepass
  entity_pass
  sweep
  mention_completion
  act_pass
  appearance_pass
  apply
  completed
  failed
  superseded
}

enum MentionRouting {
  deterministic
  patch
}

enum MentionDecisionStatus {
  pending
  accepted
  rejected
}

enum MentionCandidateType {
  alias
  role
  coreference
  ambiguous
}

enum MentionType {
  named
  alias
  descriptor
  pronoun
}

enum AliasType {
  name
  nickname
  title
  descriptor
}

enum AppearanceScope {
  stable
  temporary
  scene
}

enum BookFormat {
  fb2
  fb2_zip
}

enum BookAnalysisState {
  queued
  running
  completed
  failed
}

enum BookAnalyzerType {
  summary
  characters
  themes
  locations
  quotes
  literary
  chat_index
  core_window_scan
  core_merge
  core_resolve
  core_entity_mentions
  core_profiles
  core_quotes_finalize
  core_literary
  events
  canonical_text
  scene_build
  entity_graph
  event_relation_graph
  summary_store
  evidence_store
  text_index
  quote_store
}

enum BookGraphEntityType {
  character
  location
  group
  object
  theme
  motif
  concept
}

enum BookEventEdgeType {
  before
  after
  causes
  results_in
  parallels
}

enum BookRelationEdgeType {
  ally
  family
  romance
  conflict
  authority
  dependence
  rivalry
  mirror
  symbolic_association
}

enum BookSummaryArtifactKind {
  book_brief
  scene_summary
  chapter_summary
  entity_summary
  character_arc
  relationship_summary
  theme_note
  motif_note
  chapter_retelling
  literary_section
}

enum BookEvidenceSubjectType {
  scene
  event
  relation
  summary_artifact
  entity
}

enum BookEvidenceRefType {
  scene
  paragraph
  sentence
  quote
}

enum BookQuoteType {
  dialogue
  monologue
  narration
  description
  reflection
  action
}

enum BookQuoteTag {
  conflict
  relationship
  identity
  morality
  power
  freedom
  fear
  guilt
  hope
  fate
  society
  violence
  love
  death
  faith
}

enum BookQuoteMentionKind {
  character
  theme
  location
}

enum BookRefResolutionStatus {
  resolved
  unresolved
}

enum ProjectImportState {
  queued
  running
  completed
  failed
}

enum ProjectImportStage {
  queued
  loading_source
  parsing
  persisting
  scheduling_analysis
  completed
  failed
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner                User? @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  chapters             Chapter[]
  documents            Document[]
  acts                 Act[]
  entities             Entity[]
  appearanceObservations CharacterAppearanceObservation[]
  analysisRuns         AnalysisRun[]
  locationContainments LocationContainment[]
  projectImports       ProjectImport[]

  @@index([ownerUserId])
}

model Book {
  id              String   @id @default(cuid())
  ownerUserId     String
  title           String
  author          String?
  summary         String?
  chapterCount    Int      @default(0)
  isPublic        Boolean  @default(true)
  analysisState   BookAnalysisState @default(queued)
  analysisError   String?
  analysisStartedAt DateTime?
  analysisCompletedAt DateTime?
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageProvider String
  storageKey      String
  fileSha256      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner    User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  chapters BookChapter[]
  analyzerTasks BookAnalyzerTask[]
  bookCharacters BookCharacter[]
  bookThemes BookTheme[]
  bookLocations BookLocation[]
  bookQuotes BookQuote[]
  chunks   BookChunk[]
  chatSessions BookChatSession[]
  literaryAnalysis BookLiteraryAnalysis?
  expertCore BookExpertCore?
  likes    BookLike[]
  paragraphs BookParagraph[]
  sentences BookSentence[]
  scenes    BookScene[]
  entities  BookEntity[]
  mentions  BookMention[]
  eventsGraph BookEvent[]
  eventEdges BookEventEdge[]
  relationEdges BookRelationEdge[]
  entityMemberships BookEntityMembership[]
  summaryArtifacts BookSummaryArtifact[]
  evidenceLinks BookEvidenceLink[]
  chatSessionStates BookChatSessionState[]

  @@index([ownerUserId, createdAt])
  @@index([isPublic, createdAt])
}

model BookLiteraryAnalysis {
  id          String   @id @default(cuid())
  bookId      String   @unique
  sectionsJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookExpertCore {
  id          String   @id @default(cuid())
  bookId      String   @unique
  version     Int      @default(1)
  snapshotJson Json
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookChapter {
  id         String   @id @default(cuid())
  bookId     String
  orderIndex Int
  title      String
  summary    String?
  rawText    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  paragraphs BookParagraph[]
  sentences BookSentence[]
  scenes BookScene[]
  mentions BookMention[]
  eventsGraph BookEvent[]
  summaryArtifacts BookSummaryArtifact[]

  @@unique([bookId, orderIndex])
  @@index([bookId, orderIndex])
}

model BookParagraph {
  id             String   @id @default(cuid())
  bookId         String
  chapterId      String
  sceneId        String?
  orderIndex     Int
  orderInChapter Int
  startChar      Int
  endChar        Int
  text           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book     Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter  BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene    BookScene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  sentences BookSentence[]
  mentions  BookMention[]

  @@unique([bookId, orderIndex])
  @@index([chapterId, orderInChapter])
  @@index([sceneId, orderIndex])
}

model BookSentence {
  id             String   @id @default(cuid())
  bookId         String
  chapterId      String
  paragraphId    String
  sceneId        String?
  orderIndex     Int
  orderInChapter Int
  orderInScene   Int
  startChar      Int
  endChar        Int
  text           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book      Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraph BookParagraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  scene     BookScene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  mentions  BookMention[]

  @@unique([bookId, orderIndex])
  @@index([paragraphId, orderIndex])
  @@index([sceneId, orderIndex])
}

model BookScene {
  id                 String   @id @default(cuid())
  bookId             String
  chapterId          String
  orderIndex         Int
  title              String?
  summary            String?  @db.Text
  startParagraphOrder Int
  endParagraphOrder  Int
  startChar          Int
  endChar            Int
  text               String   @db.Text
  embedding          Unsupported("vector(768)")?
  embeddingModel     String?
  metadataJson       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  book      Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraphs BookParagraph[]
  sentences  BookSentence[]
  mentions   BookMention[]
  eventsGraph BookEvent[]
  relationEdges BookRelationEdge[]
  entityMemberships BookEntityMembership[]
  summaryArtifacts BookSummaryArtifact[]
  firstSceneEntities BookEntity[] @relation("BookEntityFirstScene")
  lastSceneEntities  BookEntity[] @relation("BookEntityLastScene")

  @@unique([bookId, orderIndex])
  @@index([chapterId, orderIndex])
}

model BookEntity {
  id            String   @id
  bookId        String
  type          BookGraphEntityType
  canonicalName String
  normalizedName String
  summary       String   @default("") @db.Text
  metadataJson  Json?
  mentionCount  Int      @default(0)
  firstSceneId  String?
  lastSceneId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  firstScene BookScene? @relation("BookEntityFirstScene", fields: [firstSceneId], references: [id], onDelete: SetNull)
  lastScene  BookScene? @relation("BookEntityLastScene", fields: [lastSceneId], references: [id], onDelete: SetNull)
  aliases    BookEntityAlias[]
  mentions   BookMention[]
  eventParticipants BookEventParticipant[]
  summaryArtifacts BookSummaryArtifact[]
  outgoingRelations BookRelationEdge[] @relation("BookRelationFromEntity")
  incomingRelations BookRelationEdge[] @relation("BookRelationToEntity")
  collectedMemberships BookEntityMembership[] @relation("BookEntityMembershipCollection")
  memberMemberships BookEntityMembership[] @relation("BookEntityMembershipMember")
  quoteMentions BookQuoteMention[]

  @@unique([bookId, type, normalizedName])
  @@index([bookId, type, mentionCount])
  @@index([firstSceneId])
  @@index([lastSceneId])
}

model BookEntityAlias {
  id              String   @id @default(cuid())
  entityId        String
  alias           String
  normalizedAlias String
  aliasType       AliasType @default(name)
  confidence      Float     @default(1)
  createdAt       DateTime  @default(now())

  entity BookEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, normalizedAlias])
  @@index([normalizedAlias])
}

model BookMention {
  id             String      @id @default(cuid())
  bookId         String
  entityId       String
  chapterId      String
  sceneId        String
  paragraphId    String?
  sentenceId     String?
  mentionType    MentionType @default(alias)
  startChar      Int
  endChar        Int
  sourceText     String
  confidence     Float       @default(1)
  createdAt      DateTime    @default(now())

  book      Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  entity    BookEntity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  chapter   BookChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene     BookScene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  paragraph BookParagraph? @relation(fields: [paragraphId], references: [id], onDelete: SetNull)
  sentence  BookSentence? @relation(fields: [sentenceId], references: [id], onDelete: SetNull)

  @@index([bookId, entityId])
  @@index([sceneId, entityId])
  @@index([paragraphId])
  @@index([sentenceId])
}

model BookEvent {
  id         String   @id
  bookId     String
  chapterId  String
  sceneId    String?
  orderIndex Int
  title      String
  summary    String   @db.Text
  metadataJson Json?
  importance Float    @default(0.5)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book      Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene     BookScene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  participants BookEventParticipant[]
  entityMemberships BookEntityMembership[]
  outgoingEdges BookEventEdge[] @relation("BookEventEdgeFrom")
  incomingEdges BookEventEdge[] @relation("BookEventEdgeTo")

  @@unique([bookId, orderIndex])
  @@index([chapterId, orderIndex])
  @@index([sceneId])
}

model BookEventParticipant {
  id             String   @id @default(cuid())
  eventId        String
  entityId       String?
  role           String
  displayName    String
  normalizedName String
  createdAt      DateTime @default(now())

  event  BookEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entity BookEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([entityId])
}

model BookEventEdge {
  id          String   @id @default(cuid())
  bookId      String
  fromEventId String
  toEventId   String
  type        BookEventEdgeType
  confidence  Float    @default(0.7)
  createdAt   DateTime @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromEvent BookEvent @relation("BookEventEdgeFrom", fields: [fromEventId], references: [id], onDelete: Cascade)
  toEvent   BookEvent @relation("BookEventEdgeTo", fields: [toEventId], references: [id], onDelete: Cascade)

  @@unique([fromEventId, toEventId, type])
  @@index([bookId, type])
}

model BookRelationEdge {
  id           String   @id
  bookId       String
  fromEntityId String
  toEntityId   String
  type         BookRelationEdgeType
  summary      String   @db.Text
  metadataJson Json?
  confidence   Float    @default(0.7)
  sceneId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromEntity BookEntity @relation("BookRelationFromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   BookEntity @relation("BookRelationToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)
  scene      BookScene? @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@unique([bookId, fromEntityId, toEntityId, type])
  @@index([sceneId])
  @@index([bookId, type])
}

model BookEntityMembership {
  id                 String   @id @default(cuid())
  bookId             String
  collectionEntityId String
  memberEntityId     String?
  memberValue        String
  memberNormalizedValue String
  resolutionStatus   BookRefResolutionStatus @default(unresolved)
  role               String
  summary            String   @db.Text
  confidence         Float    @default(0.7)
  sceneId            String?
  eventId            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  book             Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  collectionEntity BookEntity @relation("BookEntityMembershipCollection", fields: [collectionEntityId], references: [id], onDelete: Cascade)
  memberEntity     BookEntity? @relation("BookEntityMembershipMember", fields: [memberEntityId], references: [id], onDelete: SetNull)
  scene            BookScene? @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  event            BookEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([bookId, collectionEntityId, memberNormalizedValue, role])
  @@index([bookId, collectionEntityId])
  @@index([bookId, memberEntityId])
  @@index([bookId, memberNormalizedValue])
  @@index([sceneId])
  @@index([eventId])
}

model BookSummaryArtifact {
  id         String   @id
  bookId     String
  kind       BookSummaryArtifactKind
  key        String?
  title      String
  summary    String   @db.Text
  bodyMarkdown String? @db.Text
  chapterId  String?
  sceneId    String?
  entityId   String?
  metadataJson Json?
  confidence Float    @default(0.7)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book    Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  scene   BookScene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  entity  BookEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@unique([bookId, kind, key])
  @@index([chapterId])
  @@index([sceneId])
  @@index([entityId])
}

model BookEvidenceLink {
  id              String   @id @default(cuid())
  bookId          String
  subjectType     BookEvidenceSubjectType
  subjectId       String
  evidenceType    BookEvidenceRefType
  evidenceId      String
  chapterOrderIndex Int?
  snippet         String?  @db.Text
  confidence      Float    @default(0.7)
  createdAt       DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, subjectType, subjectId])
  @@index([bookId, evidenceType, evidenceId])
}

model BookAnalyzerTask {
  id          String            @id @default(cuid())
  bookId       String
  analyzerType BookAnalyzerType
  state        BookAnalysisState @default(queued)
  error        String?
  metadataJson Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, analyzerType])
  @@index([bookId, state, analyzerType])
  @@index([state, updatedAt], map: "BookAnalyzerTask_state_updatedAt_idx")
}

model BookChunk {
  id                String   @id @default(cuid())
  bookId            String
  chapterOrderIndex Int
  chunkIndex        Int
  startChar         Int
  endChar           Int
  text              String   @db.Text
  embedding         Unsupported("vector(768)")
  embeddingModel    String
  metadataJson      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterOrderIndex, chunkIndex])
  @@index([bookId, chapterOrderIndex, chunkIndex], map: "BookChunk_bookId_chapter_chunk_idx")
}

model BookChatSession {
  id            String   @id @default(cuid())
  bookId        String
  userId        String
  title         String
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book     Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages BookChatMessage[]
  state    BookChatSessionState?

  @@index([bookId, userId, lastMessageAt], map: "BookChatSession_book_user_lastMessage_idx")
  @@index([userId, createdAt], map: "BookChatSession_user_createdAt_idx")
}

model BookChatSessionState {
  id        String   @id @default(cuid())
  sessionId String   @unique
  bookId    String
  stateJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session BookChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  book    Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, updatedAt])
}

model BookChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String   @db.Text
  citationsJson Json?
  promptTokens Int?
  completionTokens Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session BookChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt], map: "BookChatMessage_session_createdAt_idx")
}

model BookCharacter {
  id                        String   @id @default(cuid())
  bookId                    String
  name                      String
  normalizedName            String
  role                      String
  description               String
  arc                       String
  mentionCount              Int      @default(0)
  firstAppearanceChapterOrder Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  book   Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quotes BookCharacterQuote[]

  @@unique([bookId, normalizedName])
  @@index([bookId, mentionCount(sort: Desc), firstAppearanceChapterOrder, name], map: "BookCharacter_bookId_mentionCount_desc_firstAppearance_idx")
}

model BookCharacterQuote {
  id              String   @id @default(cuid())
  bookCharacterId String
  chapterOrderIndex Int
  text            String   @db.Text
  context         String   @db.Text
  createdAt       DateTime @default(now())

  character BookCharacter @relation(fields: [bookCharacterId], references: [id], onDelete: Cascade)

  @@index([bookCharacterId, chapterOrderIndex])
}

model BookTheme {
  id                        String   @id @default(cuid())
  bookId                    String
  name                      String
  normalizedName            String
  description               String
  development               String
  mentionCount              Int      @default(0)
  firstAppearanceChapterOrder Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  book   Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quotes BookThemeQuote[]

  @@unique([bookId, normalizedName])
  @@index([bookId, mentionCount(sort: Desc), firstAppearanceChapterOrder, name], map: "BookTheme_bookId_mentionCount_desc_firstAppearance_idx")
}

model BookThemeQuote {
  id          String   @id @default(cuid())
  bookThemeId String
  chapterOrderIndex Int
  text        String   @db.Text
  context     String   @db.Text
  createdAt   DateTime @default(now())

  theme BookTheme @relation(fields: [bookThemeId], references: [id], onDelete: Cascade)

  @@index([bookThemeId, chapterOrderIndex])
}

model BookLocation {
  id                        String   @id @default(cuid())
  bookId                    String
  name                      String
  normalizedName            String
  description               String
  significance              String
  mentionCount              Int      @default(0)
  firstAppearanceChapterOrder Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  book   Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quotes BookLocationQuote[]

  @@unique([bookId, normalizedName])
  @@index([bookId, mentionCount(sort: Desc), firstAppearanceChapterOrder, name], map: "BookLocation_bookId_mentionCount_desc_firstAppearance_idx")
}

model BookLocationQuote {
  id             String   @id @default(cuid())
  bookLocationId String
  chapterOrderIndex Int
  text           String   @db.Text
  context        String   @db.Text
  createdAt      DateTime @default(now())

  location BookLocation @relation(fields: [bookLocationId], references: [id], onDelete: Cascade)

  @@index([bookLocationId, chapterOrderIndex])
}

model BookQuote {
  id              String   @id @default(cuid())
  bookId          String
  chapterOrderIndex Int
  startChar       Int
  endChar         Int
  text            String   @db.Text
  type            BookQuoteType
  confidence      Float
  commentary      String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  book     Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tags     BookQuoteTagLink[]
  mentions BookQuoteMention[]

  @@index([bookId, chapterOrderIndex, startChar], map: "BookQuote_bookId_chapter_start_idx")
  @@index([bookId, type], map: "BookQuote_bookId_type_idx")
  @@index([bookId, confidence], map: "BookQuote_bookId_confidence_idx")
}

model BookQuoteTagLink {
  quoteId   String
  tag       BookQuoteTag
  createdAt DateTime @default(now())

  quote BookQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@id([quoteId, tag])
  @@index([tag], map: "BookQuoteTagLink_tag_idx")
}

model BookQuoteMention {
  id              String   @id @default(cuid())
  quoteId         String
  entityId        String?
  kind            BookQuoteMentionKind
  value           String
  normalizedValue String
  resolutionStatus BookRefResolutionStatus @default(unresolved)
  startChar       Int
  endChar         Int
  confidence      Float
  createdAt       DateTime @default(now())

  quote BookQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  entity BookEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([quoteId], map: "BookQuoteMention_quoteId_idx")
  @@index([entityId], map: "BookQuoteMention_entityId_idx")
  @@index([kind, normalizedValue, confidence], map: "BookQuoteMention_kind_normalized_confidence_idx")
}

model BookLike {
  bookId    String
  userId    String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bookId, userId])
  @@index([userId, createdAt])
  @@index([bookId, createdAt])
}

model SourceAsset {
  id         String   @id @default(cuid())
  provider   String
  storageKey String
  fileName   String
  mimeType   String
  sizeBytes  Int
  sha256     String
  createdAt  DateTime @default(now())

  projectImports ProjectImport[]

  @@index([provider, storageKey])
}

model ProjectImport {
  id            String             @id @default(cuid())
  projectId     String
  sourceAssetId String
  format        BookFormat
  state         ProjectImportState @default(queued)
  stage         ProjectImportStage @default(queued)
  error         String?
  chapterCount  Int?
  metadataJson  Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceAsset SourceAsset @relation(fields: [sourceAssetId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([state, createdAt])
}

model Chapter {
  id         String   @id @default(cuid())
  projectId  String
  title      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project                 Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document                Document?
  acts                    Act[]
  analysisRuns            AnalysisRun[]
  firstAppearanceEntities Entity[]               @relation("EntityFirstAppearanceChapter")
  lastAppearanceEntities  Entity[]               @relation("EntityLastAppearanceChapter")
  characterStats          CharacterChapterStat[]
  appearanceObservations  CharacterAppearanceObservation[]

  @@index([projectId, orderIndex])
}

model Document {
  id             String   @id @default(cuid())
  projectId      String
  chapterId      String   @unique
  content        String   @db.Text
  richContent    Json
  contentVersion Int      @default(0)
  currentRunId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter           Chapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  currentRun        AnalysisRun?       @relation("DocumentCurrentRun", fields: [currentRunId], references: [id], onDelete: SetNull)
  analysisRuns      AnalysisRun[]
  acts              Act[]
  mentions          Mention[]
  appearanceObservations CharacterAppearanceObservation[]
  mentionCandidates MentionCandidate[]

  @@index([projectId])
  @@index([chapterId])
  @@index([currentRunId])
}

model AnalysisRun {
  id                      String           @id @default(cuid())
  projectId               String
  documentId              String
  chapterId               String
  contentVersion          Int
  idempotencyKey          String?
  state                   AnalysisRunState @default(queued)
  phase                   AnalysisRunPhase @default(queued)
  error                   String?
  patchBudgetReached      Boolean          @default(false)
  uncertainCountRemaining Int              @default(0)
  eligibleTotal           Int              @default(0)
  eligibleResolved        Int              @default(0)
  routingPolicyVersion    String?
  qualityFlags            Json?
  quickSnapshot           Json?
  finalSnapshot           Json?
  supersededByRunId       String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chapter            Chapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  supersededByRun    AnalysisRun?       @relation("RunSupersede", fields: [supersededByRunId], references: [id], onDelete: SetNull)
  supersededRuns     AnalysisRun[]      @relation("RunSupersede")
  currentForDocument Document[]         @relation("DocumentCurrentRun")
  createdEntities    Entity[]           @relation("CreatedEntities")
  createdActs        Act[]              @relation("CreatedActs")
  createdAppearanceObservations CharacterAppearanceObservation[] @relation("CreatedCharacterAppearanceObservations")
  mentionCandidates  MentionCandidate[]
  mentions           Mention[]
  patchDecisions     PatchDecision[]

  @@unique([documentId, idempotencyKey])
  @@index([projectId, state])
  @@index([documentId, contentVersion])
  @@index([chapterId, createdAt])
}

model Entity {
  id                       String     @id @default(cuid())
  projectId                String
  type                     EntityType
  canonicalName            String
  normalizedName           String
  summary                  String     @default("")
  mentionCount             Int        @default(0)
  firstAppearanceChapterId String?
  firstAppearanceOffset    Int?
  lastAppearanceChapterId  String?
  lastAppearanceOffset     Int?
  status                   String     @default("active")
  createdByRunId           String?
  mergedIntoEntityId       String?
  lastSeenAt               DateTime?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  project                Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByRun           AnalysisRun?           @relation("CreatedEntities", fields: [createdByRunId], references: [id], onDelete: SetNull)
  firstAppearanceChapter Chapter?               @relation("EntityFirstAppearanceChapter", fields: [firstAppearanceChapterId], references: [id], onDelete: SetNull)
  lastAppearanceChapter  Chapter?               @relation("EntityLastAppearanceChapter", fields: [lastAppearanceChapterId], references: [id], onDelete: SetNull)
  mergedIntoEntity       Entity?                @relation("EntityMerge", fields: [mergedIntoEntityId], references: [id], onDelete: SetNull)
  mergedFromEntities     Entity[]               @relation("EntityMerge")
  aliases                EntityAlias[]
  mentions               Mention[]
  chapterStats           CharacterChapterStat[]
  actStats               CharacterActStat[]
  appearanceObservations CharacterAppearanceObservation[]
  hintedCandidates       MentionCandidate[]
  containerLinks         LocationContainment[]  @relation("LocationContainmentChild")
  containedByLinks       LocationContainment[]  @relation("LocationContainmentParent")

  @@unique([projectId, type, normalizedName])
  @@index([projectId, type, canonicalName])
  @@index([projectId, type, normalizedName])
  @@index([projectId, type, mentionCount])
  @@index([firstAppearanceChapterId])
  @@index([lastAppearanceChapterId])
}

model Act {
  id             String   @id @default(cuid())
  projectId      String
  chapterId      String
  documentId     String
  contentVersion Int
  orderIndex     Int
  title          String
  summary        String   @default("")
  paragraphStart Int
  paragraphEnd   Int
  createdByRunId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdByRun AnalysisRun? @relation("CreatedActs", fields: [createdByRunId], references: [id], onDelete: SetNull)
  mentions     Mention[]
  characterStats CharacterActStat[]
  appearanceObservations CharacterAppearanceObservation[]

  @@unique([documentId, contentVersion, orderIndex])
  @@index([projectId, chapterId, orderIndex])
  @@index([documentId, contentVersion, orderIndex])
  @@index([chapterId, contentVersion, orderIndex])
  @@index([createdByRunId])
}

model EntityAlias {
  id              String    @id @default(cuid())
  entityId        String
  alias           String
  normalizedAlias String
  aliasType       AliasType @default(name)
  source          String
  confidence      Float
  observed        Boolean   @default(true)
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, normalizedAlias])
  @@index([entityId])
  @@index([normalizedAlias])
}

model MentionCandidate {
  id              String                @id @default(cuid())
  runId           String
  documentId      String
  contentVersion  Int
  paragraphIndex  Int
  startOffset     Int
  endOffset       Int
  sourceText      String
  candidateType   MentionCandidateType
  routing         MentionRouting        @default(deterministic)
  decisionStatus  MentionDecisionStatus @default(pending)
  confidence      Float                 @default(0)
  featuresJson    Json?
  conflictGroupId String?
  entityHintId    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  run        AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityHint Entity?     @relation(fields: [entityHintId], references: [id], onDelete: SetNull)
  mentions   Mention[]

  @@index([runId])
  @@index([documentId, paragraphIndex])
  @@index([decisionStatus])
}

model Mention {
  id             String      @id @default(cuid())
  runId          String
  documentId     String
  contentVersion Int
  entityId       String
  candidateId    String?
  actId          String?
  mentionType    MentionType @default(alias)
  paragraphIndex Int
  startOffset    Int
  endOffset      Int
  sourceText     String
  confidence     Float       @default(1)
  resolvedBy     String      @default("deterministic")
  createdAt      DateTime    @default(now())

  run       AnalysisRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entity    Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  act       Act?              @relation(fields: [actId], references: [id], onDelete: SetNull)
  candidate MentionCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  appearanceEvidence CharacterAppearanceEvidence[]

  @@index([documentId, paragraphIndex])
  @@index([documentId, entityId])
  @@index([documentId, contentVersion, entityId])
  @@index([entityId, mentionType])
  @@index([actId])
  @@index([entityId, actId])
  @@index([runId])
  @@index([candidateId])
}

model CharacterChapterStat {
  id           String   @id @default(cuid())
  characterId  String
  chapterId    String
  mentionCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  character Entity  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([characterId, chapterId])
  @@index([chapterId])
}

model CharacterActStat {
  id           String   @id @default(cuid())
  characterId  String
  actId        String
  mentionCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  character Entity @relation(fields: [characterId], references: [id], onDelete: Cascade)
  act       Act    @relation(fields: [actId], references: [id], onDelete: Cascade)

  @@unique([characterId, actId])
  @@index([actId])
}

model CharacterAppearanceObservation {
  id             String          @id @default(cuid())
  projectId      String
  chapterId      String
  documentId     String
  contentVersion Int
  runId          String?
  characterId    String
  actId          String?
  orderIndex     Int
  attributeKey   String
  attributeLabel String
  valueText      String
  summary        String          @default("")
  scope          AppearanceScope @default(scene)
  confidence     Float           @default(0.6)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter   Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  document  Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  run       AnalysisRun? @relation("CreatedCharacterAppearanceObservations", fields: [runId], references: [id], onDelete: SetNull)
  character Entity       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  act       Act?         @relation(fields: [actId], references: [id], onDelete: SetNull)
  evidence  CharacterAppearanceEvidence[]

  @@index([projectId, characterId, chapterId, orderIndex])
  @@index([documentId, contentVersion, orderIndex])
  @@index([characterId, actId])
  @@index([runId])
}

model CharacterAppearanceEvidence {
  id            String   @id @default(cuid())
  observationId String
  mentionId     String
  evidenceOrder Int      @default(0)
  paragraphIndex Int
  startOffset   Int
  endOffset     Int
  sourceText    String
  snippet       String
  createdAt     DateTime @default(now())

  observation CharacterAppearanceObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  mention     Mention                      @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@unique([observationId, mentionId])
  @@index([observationId, evidenceOrder])
  @@index([mentionId])
}

model PatchDecision {
  id                 String   @id @default(cuid())
  runId              String
  windowKey          String
  inputCandidateIds  String[] @default([])
  model              String
  usageJson          Json?
  applied            Boolean  @default(false)
  validationError    String?
  responseHashSha256 String?
  rawResponseSnippet String?
  responseBytes      Int?
  blobKey            String?
  createdAt          DateTime @default(now())

  run AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, windowKey])
}

model Outbox {
  id            String    @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payloadJson   Json
  availableAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  error         String?
  attemptCount  Int       @default(0)

  @@index([processedAt, createdAt])
  @@index([processedAt, availableAt, createdAt], map: "Outbox_processedAt_availableAt_createdAt_idx")
  @@index([aggregateType, aggregateId])
}

model LocationContainment {
  id             String   @id @default(cuid())
  projectId      String
  childEntityId  String
  parentEntityId String
  createdAt      DateTime @default(now())

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  childEntity  Entity  @relation("LocationContainmentChild", fields: [childEntityId], references: [id], onDelete: Cascade)
  parentEntity Entity  @relation("LocationContainmentParent", fields: [parentEntityId], references: [id], onDelete: Cascade)

  @@unique([childEntityId])
  @@unique([childEntityId, parentEntityId])
  @@index([projectId, parentEntityId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  defaultBookVisibilityPublic Boolean @default(true)
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  books         Book[]
  bookLikes     BookLike[]
  bookChatSessions BookChatSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
