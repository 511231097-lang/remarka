generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  character
  location
  event
}

enum AnalysisRunState {
  queued
  running
  completed
  failed
  superseded
}

enum AnalysisRunPhase {
  queued
  prepass
  entity_pass
  sweep
  mention_completion
  act_pass
  appearance_pass
  apply
  completed
  failed
  superseded
}

enum MentionRouting {
  deterministic
  patch
}

enum MentionDecisionStatus {
  pending
  accepted
  rejected
}

enum MentionCandidateType {
  alias
  role
  coreference
  ambiguous
}

enum MentionType {
  named
  alias
  descriptor
  pronoun
}

enum AliasType {
  name
  nickname
  title
  descriptor
}

enum AppearanceScope {
  stable
  temporary
  scene
}

enum BookFormat {
  fb2
  fb2_zip
}

enum ProjectImportState {
  queued
  running
  completed
  failed
}

enum ProjectImportStage {
  queued
  loading_source
  parsing
  persisting
  scheduling_analysis
  completed
  failed
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters             Chapter[]
  documents            Document[]
  acts                 Act[]
  entities             Entity[]
  appearanceObservations CharacterAppearanceObservation[]
  analysisRuns         AnalysisRun[]
  locationContainments LocationContainment[]
  projectImports       ProjectImport[]
}

model SourceAsset {
  id         String   @id @default(cuid())
  provider   String
  storageKey String
  fileName   String
  mimeType   String
  sizeBytes  Int
  sha256     String
  createdAt  DateTime @default(now())

  projectImports ProjectImport[]

  @@index([provider, storageKey])
}

model ProjectImport {
  id            String             @id @default(cuid())
  projectId     String
  sourceAssetId String
  format        BookFormat
  state         ProjectImportState @default(queued)
  stage         ProjectImportStage @default(queued)
  error         String?
  chapterCount  Int?
  metadataJson  Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceAsset SourceAsset @relation(fields: [sourceAssetId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([state, createdAt])
}

model Chapter {
  id         String   @id @default(cuid())
  projectId  String
  title      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project                 Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document                Document?
  acts                    Act[]
  analysisRuns            AnalysisRun[]
  firstAppearanceEntities Entity[]               @relation("EntityFirstAppearanceChapter")
  lastAppearanceEntities  Entity[]               @relation("EntityLastAppearanceChapter")
  characterStats          CharacterChapterStat[]
  appearanceObservations  CharacterAppearanceObservation[]

  @@index([projectId, orderIndex])
}

model Document {
  id             String   @id @default(cuid())
  projectId      String
  chapterId      String   @unique
  content        String   @db.Text
  richContent    Json
  contentVersion Int      @default(0)
  currentRunId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter           Chapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  currentRun        AnalysisRun?       @relation("DocumentCurrentRun", fields: [currentRunId], references: [id], onDelete: SetNull)
  analysisRuns      AnalysisRun[]
  acts              Act[]
  mentions          Mention[]
  appearanceObservations CharacterAppearanceObservation[]
  mentionCandidates MentionCandidate[]

  @@index([projectId])
  @@index([chapterId])
  @@index([currentRunId])
}

model AnalysisRun {
  id                      String           @id @default(cuid())
  projectId               String
  documentId              String
  chapterId               String
  contentVersion          Int
  idempotencyKey          String?
  state                   AnalysisRunState @default(queued)
  phase                   AnalysisRunPhase @default(queued)
  error                   String?
  patchBudgetReached      Boolean          @default(false)
  uncertainCountRemaining Int              @default(0)
  eligibleTotal           Int              @default(0)
  eligibleResolved        Int              @default(0)
  routingPolicyVersion    String?
  qualityFlags            Json?
  quickSnapshot           Json?
  finalSnapshot           Json?
  supersededByRunId       String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chapter            Chapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  supersededByRun    AnalysisRun?       @relation("RunSupersede", fields: [supersededByRunId], references: [id], onDelete: SetNull)
  supersededRuns     AnalysisRun[]      @relation("RunSupersede")
  currentForDocument Document[]         @relation("DocumentCurrentRun")
  createdEntities    Entity[]           @relation("CreatedEntities")
  createdActs        Act[]              @relation("CreatedActs")
  createdAppearanceObservations CharacterAppearanceObservation[] @relation("CreatedCharacterAppearanceObservations")
  mentionCandidates  MentionCandidate[]
  mentions           Mention[]
  patchDecisions     PatchDecision[]

  @@unique([documentId, idempotencyKey])
  @@index([projectId, state])
  @@index([documentId, contentVersion])
  @@index([chapterId, createdAt])
}

model Entity {
  id                       String     @id @default(cuid())
  projectId                String
  type                     EntityType
  canonicalName            String
  normalizedName           String
  summary                  String     @default("")
  mentionCount             Int        @default(0)
  firstAppearanceChapterId String?
  firstAppearanceOffset    Int?
  lastAppearanceChapterId  String?
  lastAppearanceOffset     Int?
  status                   String     @default("active")
  createdByRunId           String?
  mergedIntoEntityId       String?
  lastSeenAt               DateTime?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  project                Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByRun           AnalysisRun?           @relation("CreatedEntities", fields: [createdByRunId], references: [id], onDelete: SetNull)
  firstAppearanceChapter Chapter?               @relation("EntityFirstAppearanceChapter", fields: [firstAppearanceChapterId], references: [id], onDelete: SetNull)
  lastAppearanceChapter  Chapter?               @relation("EntityLastAppearanceChapter", fields: [lastAppearanceChapterId], references: [id], onDelete: SetNull)
  mergedIntoEntity       Entity?                @relation("EntityMerge", fields: [mergedIntoEntityId], references: [id], onDelete: SetNull)
  mergedFromEntities     Entity[]               @relation("EntityMerge")
  aliases                EntityAlias[]
  mentions               Mention[]
  chapterStats           CharacterChapterStat[]
  actStats               CharacterActStat[]
  appearanceObservations CharacterAppearanceObservation[]
  hintedCandidates       MentionCandidate[]
  containerLinks         LocationContainment[]  @relation("LocationContainmentChild")
  containedByLinks       LocationContainment[]  @relation("LocationContainmentParent")

  @@unique([projectId, type, normalizedName])
  @@index([projectId, type, canonicalName])
  @@index([projectId, type, normalizedName])
  @@index([projectId, type, mentionCount])
  @@index([firstAppearanceChapterId])
  @@index([lastAppearanceChapterId])
}

model Act {
  id             String   @id @default(cuid())
  projectId      String
  chapterId      String
  documentId     String
  contentVersion Int
  orderIndex     Int
  title          String
  summary        String   @default("")
  paragraphStart Int
  paragraphEnd   Int
  createdByRunId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdByRun AnalysisRun? @relation("CreatedActs", fields: [createdByRunId], references: [id], onDelete: SetNull)
  mentions     Mention[]
  characterStats CharacterActStat[]
  appearanceObservations CharacterAppearanceObservation[]

  @@unique([documentId, contentVersion, orderIndex])
  @@index([projectId, chapterId, orderIndex])
  @@index([documentId, contentVersion, orderIndex])
  @@index([chapterId, contentVersion, orderIndex])
  @@index([createdByRunId])
}

model EntityAlias {
  id              String    @id @default(cuid())
  entityId        String
  alias           String
  normalizedAlias String
  aliasType       AliasType @default(name)
  source          String
  confidence      Float
  observed        Boolean   @default(true)
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, normalizedAlias])
  @@index([entityId])
  @@index([normalizedAlias])
}

model MentionCandidate {
  id              String                @id @default(cuid())
  runId           String
  documentId      String
  contentVersion  Int
  paragraphIndex  Int
  startOffset     Int
  endOffset       Int
  sourceText      String
  candidateType   MentionCandidateType
  routing         MentionRouting        @default(deterministic)
  decisionStatus  MentionDecisionStatus @default(pending)
  confidence      Float                 @default(0)
  featuresJson    Json?
  conflictGroupId String?
  entityHintId    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  run        AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityHint Entity?     @relation(fields: [entityHintId], references: [id], onDelete: SetNull)
  mentions   Mention[]

  @@index([runId])
  @@index([documentId, paragraphIndex])
  @@index([decisionStatus])
}

model Mention {
  id             String      @id @default(cuid())
  runId          String
  documentId     String
  contentVersion Int
  entityId       String
  candidateId    String?
  actId          String?
  mentionType    MentionType @default(alias)
  paragraphIndex Int
  startOffset    Int
  endOffset      Int
  sourceText     String
  confidence     Float       @default(1)
  resolvedBy     String      @default("deterministic")
  createdAt      DateTime    @default(now())

  run       AnalysisRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entity    Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  act       Act?              @relation(fields: [actId], references: [id], onDelete: SetNull)
  candidate MentionCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  appearanceEvidence CharacterAppearanceEvidence[]

  @@index([documentId, paragraphIndex])
  @@index([documentId, entityId])
  @@index([documentId, contentVersion, entityId])
  @@index([entityId, mentionType])
  @@index([actId])
  @@index([entityId, actId])
  @@index([runId])
  @@index([candidateId])
}

model CharacterChapterStat {
  id           String   @id @default(cuid())
  characterId  String
  chapterId    String
  mentionCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  character Entity  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([characterId, chapterId])
  @@index([chapterId])
}

model CharacterActStat {
  id           String   @id @default(cuid())
  characterId  String
  actId        String
  mentionCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  character Entity @relation(fields: [characterId], references: [id], onDelete: Cascade)
  act       Act    @relation(fields: [actId], references: [id], onDelete: Cascade)

  @@unique([characterId, actId])
  @@index([actId])
}

model CharacterAppearanceObservation {
  id             String          @id @default(cuid())
  projectId      String
  chapterId      String
  documentId     String
  contentVersion Int
  runId          String?
  characterId    String
  actId          String?
  orderIndex     Int
  attributeKey   String
  attributeLabel String
  valueText      String
  summary        String          @default("")
  scope          AppearanceScope @default(scene)
  confidence     Float           @default(0.6)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter   Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  document  Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  run       AnalysisRun? @relation("CreatedCharacterAppearanceObservations", fields: [runId], references: [id], onDelete: SetNull)
  character Entity       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  act       Act?         @relation(fields: [actId], references: [id], onDelete: SetNull)
  evidence  CharacterAppearanceEvidence[]

  @@index([projectId, characterId, chapterId, orderIndex])
  @@index([documentId, contentVersion, orderIndex])
  @@index([characterId, actId])
  @@index([runId])
}

model CharacterAppearanceEvidence {
  id            String   @id @default(cuid())
  observationId String
  mentionId     String
  evidenceOrder Int      @default(0)
  paragraphIndex Int
  startOffset   Int
  endOffset     Int
  sourceText    String
  snippet       String
  createdAt     DateTime @default(now())

  observation CharacterAppearanceObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  mention     Mention                      @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@unique([observationId, mentionId])
  @@index([observationId, evidenceOrder])
  @@index([mentionId])
}

model PatchDecision {
  id                 String   @id @default(cuid())
  runId              String
  windowKey          String
  inputCandidateIds  String[] @default([])
  model              String
  usageJson          Json?
  applied            Boolean  @default(false)
  validationError    String?
  responseHashSha256 String?
  rawResponseSnippet String?
  responseBytes      Int?
  blobKey            String?
  createdAt          DateTime @default(now())

  run AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, windowKey])
}

model Outbox {
  id            String    @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payloadJson   Json
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  error         String?
  attemptCount  Int       @default(0)

  @@index([processedAt, createdAt])
  @@index([aggregateType, aggregateId])
}

model LocationContainment {
  id             String   @id @default(cuid())
  projectId      String
  childEntityId  String
  parentEntityId String
  createdAt      DateTime @default(now())

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  childEntity  Entity  @relation("LocationContainmentChild", fields: [childEntityId], references: [id], onDelete: Cascade)
  parentEntity Entity  @relation("LocationContainmentParent", fields: [parentEntityId], references: [id], onDelete: Cascade)

  @@unique([childEntityId])
  @@unique([childEntityId, parentEntityId])
  @@index([projectId, parentEntityId])
}
