generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  character
  location
  event
}

enum AnalysisStatus {
  idle
  queued
  running
  completed
  failed
}

enum AnalysisJobStatus {
  queued
  running
  completed
  failed
  stale
}

model Project {
  id          String       @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  chapters    Chapter[]
  documents   Document[]
  entities    Entity[]
  analysisJobs AnalysisJob[]
  locationContainments LocationContainment[]
}

model Chapter {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document  Document?

  @@index([projectId, orderIndex])
}

model Document {
  id                 String         @id @default(cuid())
  projectId          String
  chapterId          String         @unique
  content            String         @db.Text
  richContent        Json
  lastAnalyzedContent String?       @db.Text
  contentVersion     Int            @default(0)
  analysisStatus     AnalysisStatus @default(idle)
  lastAnalyzedVersion Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  mentions    Mention[]
  annotations Annotation[]
  analysisJobs AnalysisJob[]

  @@index([projectId])
  @@index([chapterId])
}

model Entity {
  id             String    @id @default(cuid())
  projectId      String
  type           EntityType
  name           String
  normalizedName String
  summary        String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentions           Mention[]
  annotations        Annotation[]
  containerLinks     LocationContainment[] @relation("LocationContainmentChild")
  containedByLinks   LocationContainment[] @relation("LocationContainmentParent")

  @@index([projectId, type, name])
  @@index([projectId, type, normalizedName])
}

model Mention {
  id            String   @id @default(cuid())
  entityId      String
  documentId    String
  startOffset   Int
  endOffset     Int
  paragraphIndex Int
  sourceText    String
  createdAt     DateTime @default(now())

  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, paragraphIndex])
  @@index([entityId])
}

model Annotation {
  id             String    @id @default(cuid())
  documentId     String
  paragraphIndex Int
  entityId       String?
  type           EntityType
  label          String
  createdAt      DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entity   Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([documentId, paragraphIndex])
  @@index([entityId])
}

model AnalysisJob {
  id             String           @id @default(cuid())
  projectId      String
  documentId     String
  contentVersion Int
  status         AnalysisJobStatus @default(queued)
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  modelCalls AnalysisModelCall[]
  stageMetrics AnalysisJobStageMetric[]

  @@index([documentId, createdAt])
  @@index([projectId, status])
}

model AnalysisModelCall {
  id                     String   @id @default(cuid())
  analysisJobId          String
  phase                  String
  extractionMode         String
  batchIndex             Int?
  targetParagraphIndices Int[]    @default([])
  model                  String
  attempt                Int      @default(1)
  finishReason           String?
  prompt                 String   @db.Text
  rawResponse            String   @db.Text
  jsonCandidate          String?  @db.Text
  normalizedPayload      Json?
  parseError             String?
  requestStartedAt       DateTime?
  requestCompletedAt     DateTime?
  durationMs             Int?
  createdAt              DateTime @default(now())

  analysisJob AnalysisJob @relation(fields: [analysisJobId], references: [id], onDelete: Cascade)

  @@index([analysisJobId, createdAt])
}

model AnalysisJobStageMetric {
  id                 String   @id @default(cuid())
  analysisJobId      String
  stage              String
  startedAt          DateTime
  completedAt        DateTime
  durationMs         Int
  metadata           Json?
  createdAt          DateTime @default(now())

  analysisJob AnalysisJob @relation(fields: [analysisJobId], references: [id], onDelete: Cascade)

  @@index([analysisJobId, createdAt])
  @@index([analysisJobId, stage])
}

model LocationContainment {
  id             String   @id @default(cuid())
  projectId      String
  childEntityId  String
  parentEntityId String
  createdAt      DateTime @default(now())

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  childEntity  Entity  @relation("LocationContainmentChild", fields: [childEntityId], references: [id], onDelete: Cascade)
  parentEntity Entity  @relation("LocationContainmentParent", fields: [parentEntityId], references: [id], onDelete: Cascade)

  @@unique([childEntityId])
  @@unique([childEntityId, parentEntityId])
  @@index([projectId, parentEntityId])
}
