generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MentionType {
  named
  alias
  descriptor
  pronoun
}

enum AliasType {
  name
  nickname
  title
  descriptor
}

enum BookFormat {
  fb2
  fb2_zip
}

enum BookAnalysisState {
  queued
  running
  completed
  failed
}

enum AnalysisStatus {
  not_started
  queued
  running
  completed
  failed
}

enum UserRole {
  user
  admin
}

enum BookAnalyzerType {
  summary
  characters
  themes
  locations
  quotes
  literary
  chat_index
  core_window_scan
  core_merge
  core_resolve
  core_entity_mentions
  core_profiles
  core_quotes_finalize
  core_literary
  events
  canonical_text
  scene_build
  entity_graph
  event_relation_graph
  summary_store
  evidence_store
  text_index
  quote_store
}

enum BookGraphEntityType {
  character
  location
  group
  object
  theme
  motif
  concept
}

enum BookEventEdgeType {
  before
  after
  causes
  results_in
  parallels
}

enum BookRelationEdgeType {
  ally
  family
  romance
  conflict
  authority
  dependence
  rivalry
  mirror
  symbolic_association
}

enum BookSummaryArtifactKind {
  book_brief
  scene_summary
  chapter_summary
  entity_summary
  character_arc
  relationship_summary
  theme_note
  motif_note
  chapter_retelling
  literary_section
}

enum BookEvidenceSubjectType {
  scene
  event
  relation
  summary_artifact
  entity
}

enum BookEvidenceRefType {
  scene
  paragraph
  sentence
  quote
}

enum BookQuoteType {
  dialogue
  monologue
  narration
  description
  reflection
  action
}

enum BookQuoteTag {
  conflict
  relationship
  identity
  morality
  power
  freedom
  fear
  guilt
  hope
  fate
  society
  violence
  love
  death
  faith
}

enum BookQuoteMentionKind {
  character
  theme
  location
}

enum BookRefResolutionStatus {
  resolved
  unresolved
}

enum BookAnalysisRunState {
  queued
  running
  completed
  failed
  superseded
}

enum BookEvidenceStageKey {
  ingest_normalize
  structural_pass
  local_extraction_mentions
  local_extraction_quotes
  local_extraction_events
  local_extraction_relations
  local_extraction_time_location
  validation_pass
  entity_resolution
  scene_assembly
  event_timeline
  relation_aggregation
  summary_synthesis
  index_build
  repair
  paragraph_embeddings
  scene_chunk_llm
  scene_embeddings
  evidence_fragments
  finalize
}

enum BookObservationType {
  mention
  quote
  scene_boundary
  event
  relation
  location
  time_marker
}

enum BookObservationCertainty {
  explicit
  implied
  uncertain
}

enum BookObservationValidationStatus {
  pending
  valid
  invalid
}

enum BookCanonicalEntityStatus {
  active
  ambiguous
  merged
}

enum BookTimelineOrder {
  before
  after
  same
  uncertain
}

enum BookSummaryTargetType {
  entity
  scene
  chapter
  book
  arc
  relation
}

enum BookSummaryKind {
  short
  full
  timeline
  role
  relation_history
}

enum BookCoverageStatus {
  full
  partial
}

model Book {
  id                       String            @id @default(cuid())
  ownerUserId              String
  title                    String
  author                   String?
  coverUrl                 String?
  summary                  String?
  chapterCount             Int               @default(0)
  isPublic                 Boolean           @default(false)
  analysisState            BookAnalysisState @default(queued)
  analysisStatus           AnalysisStatus    @default(not_started)
  analysisError            String?
  analysisTotalBlocks      Int               @default(0)
  analysisCheckedBlocks    Int               @default(0)
  analysisPromptTokens     Int               @default(0)
  analysisCompletionTokens Int               @default(0)
  analysisTotalTokens      Int               @default(0)
  analysisChapterStatsJson Json              @default("[]")
  analysisRequestedAt      DateTime?
  analysisStartedAt        DateTime?
  analysisFinishedAt       DateTime?
  analysisCompletedAt      DateTime?
  currentAnalysisRunId     String?
  latestAnalysisRunId      String?
  fileName                 String
  mimeType                 String
  sizeBytes                Int
  storageProvider          String
  storageKey               String
  fileSha256               String
  textCorpusStorageProvider String?
  textCorpusStorageKey     String?
  textCorpusSizeBytes      Int?
  textCorpusSha256         String?
  textCorpusCompression    String?
  textCorpusSchemaVersion  String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  owner                User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  chapters             BookChapter[]
  analyzerTasks        BookAnalyzerTask[]
  bookCharacters       BookCharacter[]
  bookThemes           BookTheme[]
  bookLocations        BookLocation[]
  bookQuotes           BookQuote[]
  chunks               BookChunk[]
  chatSessions         BookChatSession[]
  literaryAnalysis     BookLiteraryAnalysis?
  expertCore           BookExpertCore?
  likes                BookLike[]
  paragraphs           BookParagraph[]
  sentences            BookSentence[]
  scenes               BookScene[]
  entities             BookEntity[]
  mentions             BookMention[]
  eventsGraph          BookEvent[]
  eventEdges           BookEventEdge[]
  relationEdges        BookRelationEdge[]
  entityMemberships    BookEntityMembership[]
  summaryArtifacts     BookSummaryArtifact[]
  evidenceLinks        BookEvidenceLink[]
  chatSessionStates    BookChatSessionState[]
  contentVersionsV2    BookContentVersion[]
  analysisRunsV2       BookAnalysisRun[]
  stageExecutionsV2    BookStageExecution[]
  analysisChapterMetricsV2 BookAnalysisChapterMetric[]
  validationFailuresV2 BookValidationFailure[]
  sourceChaptersV2     BookSourceChapter[]
  sourceParagraphsV2   BookSourceParagraph[]
  analysisWindowsV2    BookAnalysisWindow[]
  observationsV2       BookObservation[]
  canonicalEntitiesV2  BookCanonicalEntity[]
  canonicalAliasesV2   BookCanonicalAlias[]
  canonicalScenesV2    BookCanonicalScene[]
  canonicalEventsV2    BookCanonicalEvent[]
  timelineEdgesV2      BookTimelineEdge[]
  canonicalRelationsV2 BookCanonicalRelation[]
  canonicalQuotesV2    BookCanonicalQuote[]
  canonicalSummariesV2 BookCanonicalSummary[]
  entityCardsV2        BookEntityCard[]
  sceneCardsV2         BookSceneCard[]
  relationCardsV2      BookRelationCard[]
  timelineSlicesV2     BookTimelineSlice[]
  quoteSlicesV2        BookQuoteSlice[]
  searchDocumentsV2    BookSearchDocument[]
  evidenceHitsV2       BookEvidenceHit[]
  presenceMapsV2       BookPresenceMap[]
  processingReportsV2  BookProcessingReport[]
  analysisArtifacts    BookAnalysisArtifact[]
  analysisScenes       BookAnalysisScene[]
  sceneEmbeddings      BookSceneEmbedding[]
  paragraphEmbeddings  BookParagraphEmbedding[]
  evidenceFragments    BookEvidenceFragment[]
  evidenceFragmentEmbeddings BookEvidenceFragmentEmbedding[]
  chatThreads          BookChatThread[]
  chatTurnMetrics      BookChatTurnMetric[]

  @@index([ownerUserId, createdAt])
  @@index([isPublic, createdAt])
  @@index([latestAnalysisRunId, createdAt])
}

model BookLiteraryAnalysis {
  id           String   @id @default(cuid())
  bookId       String   @unique
  sectionsJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookExpertCore {
  id           String    @id @default(cuid())
  bookId       String    @unique
  version      Int       @default(1)
  snapshotJson Json
  generatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookChapter {
  id         String   @id @default(cuid())
  bookId     String
  orderIndex Int
  title      String
  summary    String?
  rawText    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book                Book                     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  paragraphs          BookParagraph[]
  sentences           BookSentence[]
  scenes              BookScene[]
  analysisScenes      BookAnalysisScene[]
  sceneEmbeddings     BookSceneEmbedding[]
  paragraphEmbeddings BookParagraphEmbedding[]
  evidenceFragments   BookEvidenceFragment[]
  evidenceFragmentEmbeddings BookEvidenceFragmentEmbedding[]
  analysisArtifacts   BookAnalysisArtifact[]
  analysisChapterMetricsV2 BookAnalysisChapterMetric[]
  mentions            BookMention[]
  eventsGraph         BookEvent[]
  summaryArtifacts    BookSummaryArtifact[]

  @@unique([bookId, orderIndex])
  @@index([bookId, orderIndex])
}

model BookAnalysisArtifact {
  id                  String   @id @default(cuid())
  runId               String?
  bookId              String
  chapterId           String
  chapterOrderIndex   Int
  chapterTitle        String
  chunkStartParagraph Int
  chunkEndParagraph   Int
  attempt             Int
  stageKey            BookEvidenceStageKey?
  phase               String
  status              String
  llmModel            String
  promptTokens        Int      @default(0)
  completionTokens    Int      @default(0)
  totalTokens         Int      @default(0)
  elapsedMs           Int      @default(0)
  promptText          String?  @db.Text
  inputJson           Json?
  responseText        String?  @db.Text
  parsedJson          Json?
  errorMessage        String?
  storageProvider     String?
  payloadKey          String?
  payloadSizeBytes    Int      @default(0)
  payloadSha256       String?
  compression         String?
  schemaVersion       String?
  createdAt           DateTime @default(now())

  book    Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  run     BookAnalysisRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([bookId, createdAt])
  @@index([bookId, chapterId, createdAt])
  @@index([bookId, chapterId, chunkStartParagraph, chunkEndParagraph, attempt])
  @@index([runId, createdAt])
}

model BookAnalysisScene {
  id                    String   @id @default(cuid())
  bookId                String
  chapterId             String
  sceneIndex            Int
  paragraphStart        Int
  paragraphEnd          Int
  locationLabel         String?
  timeLabel             String?
  participantsJson      Json     @default("[]")
  sceneSummary          String
  sceneCard             String
  mentionedEntitiesJson Json     @default("[]")
  locationHintsJson     Json     @default("[]")
  timeHintsJson         Json     @default("[]")
  eventLabelsJson       Json     @default("[]")
  unresolvedFormsJson   Json     @default("[]")
  factsJson             Json     @default("[]")
  evidenceSpansJson     Json     @default("[]")
  changeSignal          String
  excerptText           String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  book      Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  embedding BookSceneEmbedding?
  evidenceFragments BookEvidenceFragment[]

  @@unique([bookId, chapterId, sceneIndex])
  @@index([bookId, chapterId])
  @@index([bookId, sceneIndex])
}

model BookSceneEmbedding {
  id               String                      @id @default(cuid())
  sceneId          String                      @unique
  bookId           String
  chapterId        String
  sceneIndex       Int
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book    Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene   BookAnalysisScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([bookId, chapterId, sceneIndex])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookParagraphEmbedding {
  id               String                      @id @default(cuid())
  bookId           String
  chapterId        String
  paragraphId      String?
  paragraphIndex   Int
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book    Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraph BookParagraph? @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterId, paragraphIndex, embeddingVersion])
  @@index([bookId, chapterId, paragraphIndex])
  @@index([paragraphId])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookParagraph {
  id             String   @id @default(cuid())
  bookId         String
  chapterId      String
  chapterOrderIndex Int   @default(0)
  paragraphIndex Int      @default(0)
  sceneId        String?
  orderIndex     Int
  orderInChapter Int
  startChar      Int
  endChar        Int
  text           String   @db.Text
  textHash       String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene     BookScene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  sentences BookSentence[]
  mentions  BookMention[]
  embeddings BookParagraphEmbedding[]

  @@unique([bookId, orderIndex])
  @@unique([bookId, chapterId, paragraphIndex])
  @@index([chapterId, orderInChapter])
  @@index([chapterId, paragraphIndex])
  @@index([sceneId, orderIndex])
}

model BookEvidenceFragment {
  id               String   @id @default(cuid())
  bookId           String
  chapterId        String
  primarySceneId   String?
  sceneIdsJson     Json     @default("[]")
  fragmentType     String
  paragraphStart   Int
  paragraphEnd     Int
  orderIndex       Int
  text             String   @db.Text
  textHash         String
  embeddingVersion Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  book         Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter      BookChapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  primaryScene BookAnalysisScene?  @relation(fields: [primarySceneId], references: [id], onDelete: SetNull)
  embedding    BookEvidenceFragmentEmbedding?

  @@unique([bookId, chapterId, fragmentType, paragraphStart, paragraphEnd, embeddingVersion])
  @@index([bookId])
  @@index([bookId, chapterId])
  @@index([bookId, fragmentType])
  @@index([primarySceneId])
}

model BookEvidenceFragmentEmbedding {
  id               String                      @id @default(cuid())
  fragmentId       String                      @unique
  bookId           String
  chapterId        String
  fragmentType     String
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book     Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter  BookChapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  fragment BookEvidenceFragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)

  @@index([bookId, chapterId])
  @@index([bookId, fragmentType])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookSentence {
  id             String   @id @default(cuid())
  bookId         String
  chapterId      String
  paragraphId    String
  sceneId        String?
  orderIndex     Int
  orderInChapter Int
  orderInScene   Int
  startChar      Int
  endChar        Int
  text           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book      Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraph BookParagraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  scene     BookScene?    @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  mentions  BookMention[]

  @@unique([bookId, orderIndex])
  @@index([paragraphId, orderIndex])
  @@index([sceneId, orderIndex])
}

model BookScene {
  id                  String                      @id @default(cuid())
  bookId              String
  chapterId           String
  orderIndex          Int
  title               String?
  summary             String?                     @db.Text
  startParagraphOrder Int
  endParagraphOrder   Int
  startChar           Int
  endChar             Int
  text                String                      @db.Text
  embedding           Unsupported("vector(768)")?
  embeddingModel      String?
  metadataJson        Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  book               Book                   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter            BookChapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraphs         BookParagraph[]
  sentences          BookSentence[]
  mentions           BookMention[]
  eventsGraph        BookEvent[]
  relationEdges      BookRelationEdge[]
  entityMemberships  BookEntityMembership[]
  summaryArtifacts   BookSummaryArtifact[]
  firstSceneEntities BookEntity[]           @relation("BookEntityFirstScene")
  lastSceneEntities  BookEntity[]           @relation("BookEntityLastScene")

  @@unique([bookId, orderIndex])
  @@index([chapterId, orderIndex])
}

model BookEntity {
  id             String              @id
  bookId         String
  type           BookGraphEntityType
  canonicalName  String
  normalizedName String
  summary        String              @default("") @db.Text
  metadataJson   Json?
  mentionCount   Int                 @default(0)
  firstSceneId   String?
  lastSceneId    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  book                 Book                   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  firstScene           BookScene?             @relation("BookEntityFirstScene", fields: [firstSceneId], references: [id], onDelete: SetNull)
  lastScene            BookScene?             @relation("BookEntityLastScene", fields: [lastSceneId], references: [id], onDelete: SetNull)
  aliases              BookEntityAlias[]
  mentions             BookMention[]
  eventParticipants    BookEventParticipant[]
  summaryArtifacts     BookSummaryArtifact[]
  outgoingRelations    BookRelationEdge[]     @relation("BookRelationFromEntity")
  incomingRelations    BookRelationEdge[]     @relation("BookRelationToEntity")
  collectedMemberships BookEntityMembership[] @relation("BookEntityMembershipCollection")
  memberMemberships    BookEntityMembership[] @relation("BookEntityMembershipMember")
  quoteMentions        BookQuoteMention[]

  @@unique([bookId, type, normalizedName])
  @@index([bookId, type, mentionCount])
  @@index([firstSceneId])
  @@index([lastSceneId])
}

model BookEntityAlias {
  id              String    @id @default(cuid())
  entityId        String
  alias           String
  normalizedAlias String
  aliasType       AliasType @default(name)
  confidence      Float     @default(1)
  createdAt       DateTime  @default(now())

  entity BookEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, normalizedAlias])
  @@index([normalizedAlias])
}

model BookMention {
  id          String      @id @default(cuid())
  bookId      String
  entityId    String
  chapterId   String
  sceneId     String
  paragraphId String?
  sentenceId  String?
  mentionType MentionType @default(alias)
  startChar   Int
  endChar     Int
  sourceText  String
  confidence  Float       @default(1)
  createdAt   DateTime    @default(now())

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  entity    BookEntity     @relation(fields: [entityId], references: [id], onDelete: Cascade)
  chapter   BookChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene     BookScene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  paragraph BookParagraph? @relation(fields: [paragraphId], references: [id], onDelete: SetNull)
  sentence  BookSentence?  @relation(fields: [sentenceId], references: [id], onDelete: SetNull)

  @@index([bookId, entityId])
  @@index([sceneId, entityId])
  @@index([paragraphId])
  @@index([sentenceId])
}

model BookEvent {
  id           String   @id
  bookId       String
  chapterId    String
  sceneId      String?
  orderIndex   Int
  title        String
  summary      String   @db.Text
  metadataJson Json?
  importance   Float    @default(0.5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  book              Book                   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter           BookChapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene             BookScene?             @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  participants      BookEventParticipant[]
  entityMemberships BookEntityMembership[]
  outgoingEdges     BookEventEdge[]        @relation("BookEventEdgeFrom")
  incomingEdges     BookEventEdge[]        @relation("BookEventEdgeTo")

  @@unique([bookId, orderIndex])
  @@index([chapterId, orderIndex])
  @@index([sceneId])
}

model BookEventParticipant {
  id             String   @id @default(cuid())
  eventId        String
  entityId       String?
  role           String
  displayName    String
  normalizedName String
  createdAt      DateTime @default(now())

  event  BookEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entity BookEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([entityId])
}

model BookEventEdge {
  id          String            @id @default(cuid())
  bookId      String
  fromEventId String
  toEventId   String
  type        BookEventEdgeType
  confidence  Float             @default(0.7)
  createdAt   DateTime          @default(now())

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromEvent BookEvent @relation("BookEventEdgeFrom", fields: [fromEventId], references: [id], onDelete: Cascade)
  toEvent   BookEvent @relation("BookEventEdgeTo", fields: [toEventId], references: [id], onDelete: Cascade)

  @@unique([fromEventId, toEventId, type])
  @@index([bookId, type])
}

model BookRelationEdge {
  id           String               @id
  bookId       String
  fromEntityId String
  toEntityId   String
  type         BookRelationEdgeType
  summary      String               @db.Text
  metadataJson Json?
  confidence   Float                @default(0.7)
  sceneId      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromEntity BookEntity @relation("BookRelationFromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   BookEntity @relation("BookRelationToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)
  scene      BookScene? @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@unique([bookId, fromEntityId, toEntityId, type])
  @@index([sceneId])
  @@index([bookId, type])
}

model BookEntityMembership {
  id                    String                  @id @default(cuid())
  bookId                String
  collectionEntityId    String
  memberEntityId        String?
  memberValue           String
  memberNormalizedValue String
  resolutionStatus      BookRefResolutionStatus @default(unresolved)
  role                  String
  summary               String                  @db.Text
  confidence            Float                   @default(0.7)
  sceneId               String?
  eventId               String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  book             Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  collectionEntity BookEntity  @relation("BookEntityMembershipCollection", fields: [collectionEntityId], references: [id], onDelete: Cascade)
  memberEntity     BookEntity? @relation("BookEntityMembershipMember", fields: [memberEntityId], references: [id], onDelete: SetNull)
  scene            BookScene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  event            BookEvent?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([bookId, collectionEntityId, memberNormalizedValue, role])
  @@index([bookId, collectionEntityId])
  @@index([bookId, memberEntityId])
  @@index([bookId, memberNormalizedValue])
  @@index([sceneId])
  @@index([eventId])
}

model BookSummaryArtifact {
  id           String                  @id
  bookId       String
  kind         BookSummaryArtifactKind
  key          String?
  title        String
  summary      String                  @db.Text
  bodyMarkdown String?                 @db.Text
  chapterId    String?
  sceneId      String?
  entityId     String?
  metadataJson Json?
  confidence   Float                   @default(0.7)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  scene   BookScene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)
