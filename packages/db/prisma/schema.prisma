generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookFormat {
  fb2
  fb2_zip
}

enum BookAnalysisState {
  queued
  running
  completed
  failed
}

enum AnalysisStatus {
  not_started
  queued
  running
  completed
  failed
}

enum UserRole {
  user
  admin
}

enum BookAnalyzerType {
  summary
  characters
  themes
  locations
  quotes
  literary
  chat_index
  core_window_scan
  core_merge
  core_resolve
  core_entity_mentions
  core_profiles
  core_quotes_finalize
  core_literary
  events
  canonical_text
  scene_build
  entity_graph
  event_relation_graph
  summary_store
  evidence_store
  text_index
  quote_store
}

enum BookSummaryArtifactKind {
  book_brief
  scene_summary
  chapter_summary
  entity_summary
  character_arc
  relationship_summary
  theme_note
  motif_note
  chapter_retelling
  literary_section
}

enum BookAnalysisRunState {
  queued
  running
  completed
  failed
  superseded
}

enum BookEvidenceStageKey {
  ingest_normalize
  structural_pass
  local_extraction_mentions
  local_extraction_quotes
  local_extraction_events
  local_extraction_relations
  local_extraction_time_location
  validation_pass
  entity_resolution
  scene_assembly
  event_timeline
  relation_aggregation
  summary_synthesis
  index_build
  repair
  paragraph_embeddings
  scene_chunk_llm
  scene_embeddings
  evidence_fragments
  finalize
}

model Book {
  id                        String            @id @default(cuid())
  ownerUserId               String
  title                     String
  author                    String?
  coverUrl                  String?
  summary                   String?
  chapterCount              Int               @default(0)
  isPublic                  Boolean           @default(false)
  analysisState             BookAnalysisState @default(queued)
  analysisStatus            AnalysisStatus    @default(not_started)
  analysisError             String?
  analysisTotalBlocks       Int               @default(0)
  analysisCheckedBlocks     Int               @default(0)
  analysisPromptTokens      Int               @default(0)
  analysisCompletionTokens  Int               @default(0)
  analysisTotalTokens       Int               @default(0)
  analysisChapterStatsJson  Json              @default("[]")
  analysisRequestedAt       DateTime?
  analysisStartedAt         DateTime?
  analysisFinishedAt        DateTime?
  analysisCompletedAt       DateTime?
  currentAnalysisRunId      String?
  latestAnalysisRunId       String?
  fileName                  String
  mimeType                  String
  sizeBytes                 Int
  storageProvider           String
  storageKey                String
  fileSha256                String
  textCorpusStorageProvider String?
  textCorpusStorageKey      String?
  textCorpusSizeBytes       Int?
  textCorpusSha256          String?
  textCorpusCompression     String?
  textCorpusSchemaVersion   String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  owner                      User                            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  chapters                   BookChapter[]
  analyzerTasks              BookAnalyzerTask[]
  likes                      BookLike[]
  paragraphs                 BookParagraph[]
  sentences                  BookSentence[]
  summaryArtifacts           BookSummaryArtifact[]
  contentVersionsV2          BookContentVersion[]
  analysisRunsV2             BookAnalysisRun[]
  stageExecutionsV2          BookStageExecution[]
  analysisChapterMetricsV2   BookAnalysisChapterMetric[]
  analysisArtifacts          BookAnalysisArtifact[]
  analysisScenes             BookAnalysisScene[]
  sceneEmbeddings            BookSceneEmbedding[]
  paragraphEmbeddings        BookParagraphEmbedding[]
  evidenceFragments          BookEvidenceFragment[]
  evidenceFragmentEmbeddings BookEvidenceFragmentEmbedding[]
  chatThreads                BookChatThread[]
  chatTurnMetrics            BookChatTurnMetric[]

  @@index([ownerUserId, createdAt])
  @@index([isPublic, createdAt])
  @@index([latestAnalysisRunId, createdAt])
}

model BookChapter {
  id         String   @id @default(cuid())
  bookId     String
  orderIndex Int
  title      String
  summary    String?
  rawText    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  book                       Book                            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  paragraphs                 BookParagraph[]
  sentences                  BookSentence[]
  analysisScenes             BookAnalysisScene[]
  sceneEmbeddings            BookSceneEmbedding[]
  paragraphEmbeddings        BookParagraphEmbedding[]
  evidenceFragments          BookEvidenceFragment[]
  evidenceFragmentEmbeddings BookEvidenceFragmentEmbedding[]
  analysisArtifacts          BookAnalysisArtifact[]
  analysisChapterMetricsV2   BookAnalysisChapterMetric[]
  summaryArtifacts           BookSummaryArtifact[]

  @@unique([bookId, orderIndex])
  @@index([bookId, orderIndex])
}

model BookAnalysisArtifact {
  id                  String                @id @default(cuid())
  runId               String?
  bookId              String
  chapterId           String
  chapterOrderIndex   Int
  chapterTitle        String
  chunkStartParagraph Int
  chunkEndParagraph   Int
  attempt             Int
  stageKey            BookEvidenceStageKey?
  phase               String
  status              String
  llmModel            String
  promptTokens        Int                   @default(0)
  completionTokens    Int                   @default(0)
  totalTokens         Int                   @default(0)
  elapsedMs           Int                   @default(0)
  promptText          String?               @db.Text
  inputJson           Json?
  responseText        String?               @db.Text
  parsedJson          Json?
  errorMessage        String?
  storageProvider     String?
  payloadKey          String?
  payloadSizeBytes    Int                   @default(0)
  payloadSha256       String?
  compression         String?
  schemaVersion       String?
  createdAt           DateTime              @default(now())

  book    Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  run     BookAnalysisRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([bookId, createdAt])
  @@index([bookId, chapterId, createdAt])
  @@index([bookId, chapterId, chunkStartParagraph, chunkEndParagraph, attempt])
  @@index([runId, createdAt])
}

model BookAnalysisScene {
  id                    String   @id @default(cuid())
  bookId                String
  chapterId             String
  sceneIndex            Int
  paragraphStart        Int
  paragraphEnd          Int
  locationLabel         String?
  timeLabel             String?
  participantsJson      Json     @default("[]")
  sceneSummary          String
  sceneCard             String
  mentionedEntitiesJson Json     @default("[]")
  locationHintsJson     Json     @default("[]")
  timeHintsJson         Json     @default("[]")
  eventLabelsJson       Json     @default("[]")
  unresolvedFormsJson   Json     @default("[]")
  factsJson             Json     @default("[]")
  evidenceSpansJson     Json     @default("[]")
  changeSignal          String
  excerptText           String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  book              Book                   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter           BookChapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  embedding         BookSceneEmbedding?
  evidenceFragments BookEvidenceFragment[]

  @@unique([bookId, chapterId, sceneIndex])
  @@index([bookId, chapterId])
  @@index([bookId, sceneIndex])
}

model BookSceneEmbedding {
  id               String                      @id @default(cuid())
  sceneId          String                      @unique
  bookId           String
  chapterId        String
  sceneIndex       Int
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book    Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene   BookAnalysisScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([bookId, chapterId, sceneIndex])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookParagraphEmbedding {
  id               String                      @id @default(cuid())
  bookId           String
  chapterId        String
  paragraphId      String?
  paragraphIndex   Int
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraph BookParagraph? @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterId, paragraphIndex, embeddingVersion])
  @@index([bookId, chapterId, paragraphIndex])
  @@index([paragraphId])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookParagraph {
  id                String   @id @default(cuid())
  bookId            String
  chapterId         String
  chapterOrderIndex Int      @default(0)
  paragraphIndex    Int      @default(0)
  orderIndex        Int
  orderInChapter    Int
  startChar         Int
  endChar           Int
  text              String   @db.Text
  textHash          String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  book       Book                     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter    BookChapter              @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sentences  BookSentence[]
  embeddings BookParagraphEmbedding[]

  @@unique([bookId, orderIndex])
  @@unique([bookId, chapterId, paragraphIndex])
  @@index([chapterId, orderInChapter])
  @@index([chapterId, paragraphIndex])
}

model BookEvidenceFragment {
  id               String   @id @default(cuid())
  bookId           String
  chapterId        String
  primarySceneId   String?
  sceneIdsJson     Json     @default("[]")
  fragmentType     String
  paragraphStart   Int
  paragraphEnd     Int
  orderIndex       Int
  text             String   @db.Text
  textHash         String
  embeddingVersion Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  book         Book                           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter      BookChapter                    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  primaryScene BookAnalysisScene?             @relation(fields: [primarySceneId], references: [id], onDelete: SetNull)
  embedding    BookEvidenceFragmentEmbedding?

  @@unique([bookId, chapterId, fragmentType, paragraphStart, paragraphEnd, embeddingVersion])
  @@index([bookId])
  @@index([bookId, chapterId])
  @@index([bookId, fragmentType])
  @@index([primarySceneId])
}

model BookEvidenceFragmentEmbedding {
  id               String                      @id @default(cuid())
  fragmentId       String                      @unique
  bookId           String
  chapterId        String
  fragmentType     String
  embeddingModel   String
  embeddingVersion Int                         @default(1)
  taskType         String
  dimensions       Int
  sourceText       String                      @db.Text
  sourceTextHash   String
  vector           Unsupported("vector(768)")?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  book     Book                 @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter  BookChapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  fragment BookEvidenceFragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)

  @@index([bookId, chapterId])
  @@index([bookId, fragmentType])
  @@index([bookId, embeddingVersion])
  @@index([embeddingModel])
}

model BookSentence {
  id             String   @id @default(cuid())
  bookId         String
  chapterId      String
  paragraphId    String
  orderIndex     Int
  orderInChapter Int
  orderInScene   Int
  startChar      Int
  endChar        Int
  text           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book      Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraph BookParagraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@unique([bookId, orderIndex])
  @@index([paragraphId, orderIndex])
}

model BookSummaryArtifact {
  id           String                  @id
  bookId       String
  kind         BookSummaryArtifactKind
  key          String?
  title        String
  summary      String                  @db.Text
  bodyMarkdown String?                 @db.Text
  chapterId    String?
  metadataJson Json?
  confidence   Float                   @default(0.7)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@unique([bookId, kind, key])
  @@index([chapterId])
}

model BookAnalyzerTask {
  id           String            @id @default(cuid())
  bookId       String
  analyzerType BookAnalyzerType
  state        BookAnalysisState @default(queued)
  error        String?
  metadataJson Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, analyzerType])
  @@index([bookId, state, analyzerType])
  @@index([state, updatedAt], map: "BookAnalyzerTask_state_updatedAt_idx")
}

model BookChatThread {
  id          String   @id @default(cuid())
  bookId      String
  ownerUserId String
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // History compaction: when a thread grows past N pairs we compress the older
  // turns into a single summary string via a cheap lite-model call. The summary
  // is reused across subsequent turns until new compactable history accumulates.
  compactedHistory                 String?
  compactedHistoryThroughMessageId String?
  compactedHistoryUpdatedAt        DateTime?

  book        Book                    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  owner       User                    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages    BookChatThreadMessage[]
  turnMetrics BookChatTurnMetric[]

  @@index([bookId, updatedAt])
  @@index([ownerUserId, updatedAt])
  @@index([createdAt])
}

enum BookChatThreadMessageRole {
  user
  assistant
}

model BookChatThreadMessage {
  id            String                    @id @default(cuid())
  threadId      String
  role          BookChatThreadMessageRole
  content       String                    @db.Text
  citationsJson Json                      @default("[]")
  toolRunsJson  Json                      @default("[]")
  metricsJson   Json                      @default("{}")
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  thread     BookChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  turnMetric BookChatTurnMetric?

  @@index([threadId, createdAt])
  @@index([role, createdAt])
}

model BookLike {
  bookId    String
  userId    String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([bookId, userId])
  @@index([userId, createdAt])
  @@index([bookId, createdAt])
}

model BookContentVersion {
  id                   String     @id @default(cuid())
  bookId               String
  version              Int
  sourceFormat         BookFormat
  normalizationVersion Int        @default(1)
  fileSha256           String
  metadataJson         Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, version])
  @@index([bookId, createdAt])
}

model BookAnalysisRun {
  id                      String                @id @default(cuid())
  bookId                  String
  contentVersionId        String
  attempt                 Int                   @default(1)
  state                   BookAnalysisRunState  @default(queued)
  currentStageKey         BookEvidenceStageKey?
  error                   String?
  configVersion           String?
  configHash              String?
  extractModel            String?
  chatModel               String?
  embeddingModel          String?
  pricingVersion          String?
  llmPromptTokens         Int                   @default(0)
  llmCompletionTokens     Int                   @default(0)
  llmTotalTokens          Int                   @default(0)
  embeddingInputTokens    Int                   @default(0)
  embeddingTotalTokens    Int                   @default(0)
  llmCostUsd              Float                 @default(0)
  embeddingCostUsd        Float                 @default(0)
  totalCostUsd            Float                 @default(0)
  totalElapsedMs          Int                   @default(0)
  llmLatencyMs            Int                   @default(0)
  embeddingLatencyMs      Int                   @default(0)
  chunkCount              Int                   @default(0)
  chunkFailedCount        Int                   @default(0)
  llmCalls                Int                   @default(0)
  llmRetries              Int                   @default(0)
  embeddingCalls          Int                   @default(0)
  paragraphEmbeddingCount Int                   @default(0)
  sceneCount              Int                   @default(0)
  artifactCount           Int                   @default(0)
  storageBytesJson        Json?
  qualityFlagsJson        Json?
  metricsJson             Json?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  book            Book                        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  stageExecutions BookStageExecution[]
  chapterMetrics  BookAnalysisChapterMetric[]
  artifacts       BookAnalysisArtifact[]

  @@index([bookId, state, createdAt])
  @@index([bookId, contentVersionId])
  @@index([bookId, attempt, createdAt])
}

model BookStageExecution {
  id                   String               @id @default(cuid())
  bookId               String
  contentVersionId     String
  runId                String
  stageKey             BookEvidenceStageKey
  state                BookAnalysisState    @default(queued)
  error                String?
  promptTokens         Int                  @default(0)
  completionTokens     Int                  @default(0)
  totalTokens          Int                  @default(0)
  embeddingInputTokens Int                  @default(0)
  embeddingTotalTokens Int                  @default(0)
  llmCostUsd           Float                @default(0)
  embeddingCostUsd     Float                @default(0)
  totalCostUsd         Float                @default(0)
  elapsedMs            Int                  @default(0)
  retryCount           Int                  @default(0)
  llmCalls             Int                  @default(0)
  embeddingCalls       Int                  @default(0)
  chunkCount           Int                  @default(0)
  chunkFailedCount     Int                  @default(0)
  outputRowCount       Int                  @default(0)
  storageBytesJson     Json?
  metadataJson         Json?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  book Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  run  BookAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stageKey])
  @@index([bookId, contentVersionId, stageKey])
  @@index([state, updatedAt])
}

model BookAnalysisChapterMetric {
  id                   String               @id @default(cuid())
  bookId               String
  contentVersionId     String
  runId                String
  chapterId            String
  chapterOrderIndex    Int
  chapterTitle         String
  stageKey             BookEvidenceStageKey
  state                BookAnalysisState    @default(queued)
  error                String?
  promptTokens         Int                  @default(0)
  completionTokens     Int                  @default(0)
  totalTokens          Int                  @default(0)
  embeddingInputTokens Int                  @default(0)
  embeddingTotalTokens Int                  @default(0)
  elapsedMs            Int                  @default(0)
  retryCount           Int                  @default(0)
  llmCalls             Int                  @default(0)
  embeddingCalls       Int                  @default(0)
  chunkCount           Int                  @default(0)
  chunkFailedCount     Int                  @default(0)
  outputRowCount       Int                  @default(0)
  storageBytesJson     Json?
  metadataJson         Json?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  book    Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  run     BookAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  chapter BookChapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([runId, chapterId, stageKey])
  @@index([bookId, contentVersionId, chapterOrderIndex, stageKey])
  @@index([runId, stageKey, chapterOrderIndex])
}

model BookChatTurnMetric {
  id                     String   @id @default(cuid())
  bookId                 String
  threadId               String
  messageId              String   @unique
  chatModel              String
  embeddingModel         String
  selectedToolsJson      Json     @default("[]")
  toolConfigKey          String
  promptVariant          String
  systemPromptVersion    String
  pricingVersion         String
  modelInputTokens       Int      @default(0)
  modelOutputTokens      Int      @default(0)
  modelTotalTokens       Int      @default(0)
  // Subset of modelInputTokens that hit Vertex implicit/explicit cache. Cached
  // tokens are billed at ~10% of normal input price (90% off). When >0 means
  // implicit cache fired on this turn.
  modelCachedInputTokens Int      @default(0)
  // "Thinking" tokens for Gemini 3.x and 2.5 thinking models. Billed as output
  // tokens but invisible in the final answer text. Tracking these separately
  // lets us measure how much "internal reasoning" each turn consumed.
  modelThoughtsTokens    Int      @default(0)
  embeddingInputTokens   Int      @default(0)
  chatCostUsd            Float    @default(0)
  embeddingCostUsd       Float    @default(0)
  totalCostUsd           Float    @default(0)
  totalLatencyMs         Int      @default(0)
  answerLengthChars      Int      @default(0)
  citationCount          Int      @default(0)
  fallbackUsed           Boolean  @default(false)
  fallbackKind           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  book     Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  thread   BookChatThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message  BookChatThreadMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolRuns BookChatToolRun[]

  @@index([bookId, createdAt])
  @@index([threadId, createdAt])
}

model BookChatToolRun {
  id                String   @id @default(cuid())
  turnMetricId      String
  toolName          String
  orderIndex        Int
  latencyMs         Int      @default(0)
  argsSummaryJson   Json     @default("{}")
  resultSummaryJson Json     @default("{}")
  errorCode         String?
  errorMessage      String?
  storageProvider   String?
  payloadKey        String?
  payloadSizeBytes  Int      @default(0)
  payloadSha256     String?
  compression       String?
  createdAt         DateTime @default(now())

  turnMetric BookChatTurnMetric @relation(fields: [turnMetricId], references: [id], onDelete: Cascade)

  @@unique([turnMetricId, orderIndex])
  @@index([toolName, createdAt])
  @@index([turnMetricId, createdAt])
}

model Outbox {
  id            String    @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payloadJson   Json
  availableAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  error         String?
  attemptCount  Int       @default(0)

  @@index([processedAt, createdAt])
  @@index([processedAt, availableAt, createdAt], map: "Outbox_processedAt_availableAt_createdAt_idx")
  @@index([aggregateType, aggregateId])
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  role          UserRole         @default(user)
  accounts      Account[]
  sessions      Session[]
  books         Book[]
  bookLikes     BookLike[]
  chatThreads   BookChatThread[]
  legalConsents LegalConsent[]

  @@index([role])
}

// Audit log of every юридически-significant acceptance — registration
// galka, upload galka, cookie settings save. Lets us prove what exactly
// the user saw at the moment of consent (documentVersionHash) and what
// they consented to (consentType + payload). Required by legal review.
//
// Designed to be append-only: never UPDATE rows, only INSERT new ones.
// Old document versions stay attached to their original consents even
// after we ship a new redaction.
enum LegalConsentType {
  signin_acceptance
  upload_acceptance
  cookie_settings
}

model LegalConsent {
  id                   String           @id @default(cuid())
  userId               String?
  consentType          LegalConsentType
  acceptedAt           DateTime         @default(now())
  documentVersionHash  String
  documentVersionLabel String
  ipAddress            String?
  userAgent            String?
  relatedResourceId    String?
  cookieCategoriesJson Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, acceptedAt])
  @@index([consentType, acceptedAt])
  @@index([relatedResourceId])
}

// Жалоба правообладателя (DMCA-style notice). Поступает через форму
// /legal/copyright или резервно по почте abuse@. Структурированная запись
// для соблюдения процедуры по ст. 1253.1 ГК РФ и ст. 15.7 ФЗ «Об
// информации». Каждая жалоба фиксирует:
//   - claimant identity + contact
//   - какое произведение и где (URLs/bookId)
//   - правовое основание (договор, авторство, доверенность)
//   - подтверждение добросовестности (sworn) с хешем текста
//   - IP/UA для возможных регрессов при заведомо ложных жалобах
//   - вложения (договор, свидетельства) — стораджятся в S3
//
// status — workflow: new → under_review → accepted/rejected; counter_received
// если пришёл встречный отвод от пользователя, чей контент заблокирован.
enum CopyrightComplaintStatus {
  new
  under_review
  accepted
  rejected
  counter_received
}

enum CopyrightClaimantType {
  rightsholder
  authorized_person
  org_representative
}

model CopyrightComplaint {
  id                       String                   @id @default(cuid())
  status                   CopyrightComplaintStatus @default(new)
  claimantType             CopyrightClaimantType
  claimantName             String
  claimantOrganization     String?
  claimantEmail            String
  workTitle                String
  disputedUrls             String                   @db.Text
  rightsBasis              String                   @db.Text
  powerOfAttorneyDetails   String?                  @db.Text
  description              String                   @db.Text
  swornStatementHash       String
  swornStatementLabel      String
  attachmentsJson          Json                     @default("[]")
  ipAddress                String?
  userAgent                String?
  reviewerNotes            String?                  @db.Text
  reviewedAt               DateTime?
  reviewedByUserId         String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([claimantEmail, createdAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
