# Template for .env.eval — override storage settings so host-side
# `npm run eval:chat-regression` reads books from the MinIO container
# instead of the missing local /tmp/remarka-imports copy.
#
# Copy to .env.eval and adjust if your MinIO host port or credentials
# differ from the docker-compose defaults.
#
# Loaded by the eval command via --env-file-if-exists, AFTER .env.local /
# .env, so values here override any matching keys.

BOOKS_STORAGE_PROVIDER=s3
BOOKS_S3_ENDPOINT=http://localhost:9200
BOOKS_S3_BUCKET=remarka-books
BOOKS_S3_REGION=us-east-1
BOOKS_S3_FORCE_PATH_STYLE=true
BOOKS_S3_KEY_PREFIX=remarka/books
BOOKS_S3_ACCESS_KEY_ID=minioadmin
BOOKS_S3_SECRET_ACCESS_KEY=minioadmin

# === Top-config eval overrides (optional, mirrors prod docker chat) ===
# Without these the host-side eval would silently fall back on flash-lite even
# when the planner selects "pro" tier — see apps/web/src/lib/bookChatService.ts
# (resolveBookChatModelByTier) for the fallback chain.
BOOK_CHAT_MODEL_PRO=gemini-3.1-pro-preview
BOOK_CHAT_MODEL_LITE=gemini-3.1-flash-lite-preview
BOOK_CHAT_SCENE_TOOLS_ENABLED=true
